let verbDeck = [], verbIdx = 0, verbScore = 0, verbMode = 'all', verbAnswered = false;

function restartVerbs() {
    let base = VERBS;
    if (verbMode === 'common') base = VERBS.filter(v => v[6]);
    else if (verbMode === 'aaa') base = VERBS.filter(v => v[5] === 'aaa');
    else if (verbMode === 'abb') base = VERBS.filter(v => v[5] === 'abb');
    else if (verbMode === 'abc') base = VERBS.filter(v => v[5] === 'abc' || v[5] === 'aba');
    
    verbDeck = shuffle([...base]);
    verbIdx = 0; verbScore = 0; verbAnswered = false;
    document.getElementById('verb-score').textContent = '0';
    document.getElementById('verb-total').textContent = verbDeck.length;
    renderVerb();
}

function setVerbMode(m) {
    verbMode = m;
    document.querySelectorAll('[data-vmode]').forEach(b => b.classList.toggle('active', b.dataset.vmode === m));
    restartVerbs();
}

function renderVerb() {
    const area = document.getElementById('verb-area');
    document.getElementById('verb-score').textContent = verbScore;
    if (!verbDeck.length) { area.innerHTML = `<div class="empty-state">Sin verbos.</div>`; return; }
    if (verbIdx >= verbDeck.length) {
        area.innerHTML = `<div class="round-done"><h2>¡Completado!</h2><button class="repeat-btn" onclick="restartVerbs()">↺ Repetir</button></div>`;
        return;
    }
    verbAnswered = false;
    const v = verbDeck[verbIdx];
    const useMC = (verbMode === 'mc' || (verbMode !== 'typein' && verbIdx % 3 === 0));

    if (useMC) renderVerbMC(v, area);
    else renderVerbTypeIn(v, area);
}

function renderVerbTypeIn(v, area) {
    area.innerHTML = `
        <div class="verb-card">
            <div class="verb-infinitive">${v[0]}</div>
            <div class="verb-translation">${v[3]}</div>
            <div class="verb-grid">
                <div class="verb-input-wrap"><div class="verb-label">Past Simple</div><input class="verb-input" id="verb-past" type="text"></div>
                <div class="verb-input-wrap"><div class="verb-label">Past Participle</div><input class="verb-input" id="verb-pp" type="text"></div>
            </div>
            <button class="verb-check-btn" onclick="checkVerbTypeIn('${encodeURIComponent(v[1])}','${encodeURIComponent(v[2])}')">Comprobar</button>
            <div id="verb-feedback"></div>
        </div>
        <button class="quiz-next-btn" id="verb-next" onclick="verbNext()">Siguiente →</button>`;
}

function checkVerbTypeIn(pE, ppE) {
    if (verbAnswered) return;
    verbAnswered = true;
    const pI = document.getElementById('verb-past'), ppI = document.getElementById('verb-pp');
    const pOk = normalise(pI.value) === normalise(decodeURIComponent(pE));
    const ppOk = normalise(ppI.value) === normalise(decodeURIComponent(ppE));
    const fb = document.getElementById('verb-feedback');
    if (pOk && ppOk) {
        fb.innerHTML = "✅ Correcto!";
        verbScore++;
        setTimeout(verbNext, 1000);
    } else {
        fb.innerHTML = "❌ Incorrecto";
        document.getElementById('verb-next').classList.add('visible');
    }
    pI.classList.add(pOk ? 'correct' : 'wrong');
    ppI.classList.add(ppOk ? 'correct' : 'wrong');
    if(!pOk) pI.value = decodeURIComponent(pE);
    if(!ppOk) ppI.value = decodeURIComponent(ppE);
}

function renderVerbMC(v, area) {
    const past = v[1], pp = v[2];
    const correct = `${past} / ${pp}`;
    // Generate distractors: common mistakes
    const distractors = [];
    if (past !== pp) {
        distractors.push(`${past} / ${past}`); // same for both
        distractors.push(`${pp} / ${pp}`);
        distractors.push(`${pp} / ${past}`);
    } else {
        // For same forms like cut/cut/cut
        distractors.push(`${past}ed / ${pp}ed`);
        distractors.push(`${past} / ${past}ed`);
        distractors.push(`${past}ed / ${past}`);
    }
    // Add some generic wrong ones
    const others = shuffle(VERBS.filter(o => o[0] !== v[0])).slice(0, 2);
    others.forEach(o => distractors.push(`${o[1]} / ${o[2]}`));
    const opts = shuffle([correct, ...distractors.slice(0, 3)]);
    area.innerHTML = `
        <div class="verb-card">
            <div class="verb-infinitive">${v[0]}</div>
            <div class="verb-translation">${v[3]}</div>
            <div class="verb-instruction">Elige el par correcto: Past / Past Participle</div>
            <div class="options-grid" id="verb-opts">
                ${opts.map(o => `<button class="option-btn" onclick="checkVerbMC(this,'${encodeURIComponent(correct)}')">${o}</button>`).join('')}
            </div>
            <div id="verb-feedback"></div>
        </div>
        <button class="quiz-next-btn" id="verb-next" onclick="verbNext()">Siguiente →</button>`;
}

function checkVerbMC(btn, correctE) {
    if (verbAnswered) return;
    verbAnswered = true;
    const correct = btn.textContent === decodeURIComponent(correctE);
    const fb = document.getElementById('verb-feedback');
    if (correct) {
        fb.innerHTML = "✅ Correcto!";
        verbScore++;
        setTimeout(verbNext, 1000);
    } else {
        fb.innerHTML = "❌ Incorrecto";
        document.getElementById('verb-next').classList.add('visible');
    }
    btn.classList.add(correct ? 'correct' : 'wrong');
}

function verbNext() { verbIdx++; renderVerb(); }

/* ── INIT ── */
window.onload = () => {
    loadProgress(); loadEProgress(); loadSR(); buildTheory();
    restartRewriting(); restartDetect(); restartSpeaking(); restartVerbs();
    // Aquí puedes añadir tus fetch de JSON si los tienes en el servidor
};
/* ── INIT ── */
loadProgress();loadEProgress();loadSR();buildTheory();restartRewriting();restartDetect();restartSpeaking();restartVerbs();

fetch('vocab.json').then(r=>r.json()).then(loadData)
  .catch(()=>{const sv=loadSavedVocab();if(sv)loadData(sv);else{updateGlobalStats();updateModeCounts();}});

fetch('exercises.json').then(r=>r.json()).then(loadExercises)
  .catch(()=>{const se=loadSavedEx();if(se)loadExercises(se);});

fetch('collocations.json').then(r=>r.json()).then(loadCollocations)
  .catch(()=>document.getElementById('coll-area').innerHTML=`<div class="empty-state"><div class="big">🔗</div>No se pudo cargar collocations.json</div>`);
</script>
</body>
</html>