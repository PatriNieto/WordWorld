<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>English C1 Study</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#fff;--bg2:#f5f4f0;--bg3:#eeede9;
  --text:#1a1a1a;--text2:#666;--text3:#999;
  --border:rgba(0,0,0,0.12);--border2:rgba(0,0,0,0.22);
  --radius:10px;--radius-lg:16px;
  --accent:#3B5BDB;--accent-light:#EEF2FF;
  --green:#2F9E44;--green-light:#EBFBEE;
  --red:#E03131;--red-light:#FFF5F5;
  --orange:#E67700;--orange-light:#FFF9DB;
  --card-h:300px;
}

/* ── VERBOS ── */
.verb-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-lg);padding:18px;margin-bottom:12px}
.verb-infinitive{font-size:30px;font-weight:800;color:var(--accent);margin-bottom:4px;line-height:1.2}
.verb-translation{font-size:15px;color:var(--text3);margin-bottom:18px}
.verb-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:8px}
.verb-input-wrap{display:flex;flex-direction:column;gap:4px}
.verb-label{font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.05em}
.verb-input{width:100%;padding:12px 14px;border-radius:var(--radius);border:2px solid var(--border2);background:var(--bg);color:var(--text);font-size:16px;outline:none;transition:border-color .15s;-webkit-appearance:none;font-weight:600}
.verb-input:focus{border-color:var(--accent)}
.verb-input.correct{border-color:var(--green);background:var(--green-light);color:var(--green)}
.verb-input.wrong{border-color:var(--red);background:var(--red-light);color:var(--red)}
.verb-input.revealed{border-color:var(--accent);background:var(--accent-light);color:var(--accent);font-weight:700}
.verb-example{font-size:13px;color:var(--text2);font-style:italic;line-height:1.6;margin-top:8px;padding:8px 12px;background:var(--bg2);border-radius:8px}
.verb-check-btn{width:100%;padding:14px;border-radius:var(--radius);border:none;background:var(--accent);color:#fff;font-size:16px;font-weight:600;cursor:pointer;-webkit-tap-highlight-color:transparent;margin-top:10px}
.verb-check-btn:active{opacity:.88}
.verb-check-btn:disabled{opacity:.4;cursor:default}
.verb-mode-bar{display:flex;gap:6px;margin-bottom:12px;overflow-x:auto;padding-bottom:4px;scrollbar-width:none}
.verb-mode-bar::-webkit-scrollbar{display:none}

@media(prefers-color-scheme:dark){
  :root{--bg:#1c1c1e;--bg2:#2c2c2e;--bg3:#3a3a3c;--text:#f2f2f7;--text2:#aeaeb2;--text3:#636366;--border:rgba(255,255,255,0.1);--border2:rgba(255,255,255,0.18);--accent-light:#1a1f4a;--green-light:#0d2e15;--red-light:#2d0f0f;--orange-light:#2d1f00}
}
html{-webkit-text-size-adjust:100%}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;background:var(--bg3);color:var(--text);min-height:100vh;overscroll-behavior:none}

/* ── LAYOUT ── */
.app{max-width:600px;margin:0 auto;padding:env(safe-area-inset-top,16px) 16px env(safe-area-inset-bottom,16px)}

/* ── HEADER ── */
.header{display:flex;align-items:center;justify-content:space-between;padding:14px 0 12px;gap:8px}
.header h1{font-size:20px;font-weight:700;letter-spacing:-.3px}
.reset-btn{font-size:13px;padding:7px 13px;border-radius:var(--radius);border:1px solid var(--border2);background:var(--bg);color:var(--text2);cursor:pointer;-webkit-tap-highlight-color:transparent}

/* ── TABS (bottom nav style) ── */
.tabs{display:flex;gap:2px;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;;gap:2px;background:var(--bg2);border-radius:12px;padding:4px;margin-bottom:16px}
.tabs::-webkit-scrollbar{display:none}.tab-btn{padding:9px 8px 8px;font-size:10px;flex-shrink:0;min-width:60px;font-weight:600;border:none;border-radius:9px;background:transparent;color:var(--text3);cursor:pointer;transition:all .18s;-webkit-tap-highlight-color:transparent;display:flex;flex-direction:column;align-items:center;gap:3px;line-height:1.2}
.tab-btn .tab-icon{font-size:18px;line-height:1}
.tab-btn.active{background:var(--bg);color:var(--accent);box-shadow:0 1px 4px rgba(0,0,0,.12)}
.tab-content{display:none}
.tab-content.active{display:block}

/* ── STATS BAR ── */
.stats-bar{background:var(--bg);border-radius:var(--radius-lg);padding:14px 16px;margin-bottom:14px;border:1px solid var(--border)}
.stats-bar-title{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px}
.progress-track{height:8px;background:var(--bg3);border-radius:4px;overflow:hidden;display:flex;margin-bottom:10px}
.pt-known{background:#2F9E44;transition:width .4s}.pt-hard{background:#E67700;transition:width .4s}.pt-no{background:#E03131;transition:width .4s}
.stats-nums{display:flex;gap:0;flex-wrap:wrap}
.sn{display:flex;align-items:center;gap:5px;font-size:13px;color:var(--text2);padding:2px 10px 2px 0}
.sn:first-child{padding-left:0}
.sn-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.sn b{font-weight:700;color:var(--text)}

/* ── MODE BAR ── */
.mode-bar{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px}
.mode-btn{padding:10px 4px;font-size:13px;font-weight:500;border-radius:var(--radius);border:1px solid var(--border2);background:var(--bg);color:var(--text2);cursor:pointer;transition:all .15s;line-height:1.3;-webkit-tap-highlight-color:transparent;text-align:center}
.mode-btn.active{background:var(--accent);border-color:var(--accent);color:#fff}
.mode-btn .count{font-size:11px;display:block;opacity:.75;margin-top:1px}

/* ── TOPIC PILLS ── */
.topic-bar{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}
.topic-btn{font-size:12px;padding:6px 14px;border-radius:20px;border:1px solid var(--border2);background:var(--bg);color:var(--text2);cursor:pointer;transition:all .15s;-webkit-tap-highlight-color:transparent;white-space:nowrap}
.topic-btn.active{background:var(--accent-light);border-color:var(--accent);color:var(--accent);font-weight:600}

/* ── CARD AREA ── */
.card-area{display:flex;flex-direction:column;align-items:stretch;gap:14px}
.prog-row{display:flex;align-items:center;gap:10px}
.prog-bar{flex:1;height:5px;background:var(--bg3);border-radius:3px;overflow:hidden}
.prog-fill{height:100%;background:var(--accent);border-radius:3px;transition:width .35s}
.prog-label{font-size:13px;color:var(--text2);white-space:nowrap;font-variant-numeric:tabular-nums}

/* ── FLASHCARD ── */
.card-wrap{width:100%;perspective:1200px;height:var(--card-h);cursor:pointer;-webkit-tap-highlight-color:transparent}
.card-inner{position:relative;width:100%;height:100%;transform-style:preserve-3d;transition:transform .42s cubic-bezier(.4,0,.2,1)}
.card-wrap.flipped .card-inner{transform:rotateY(180deg)}
.card-face{position:absolute;inset:0;backface-visibility:hidden;-webkit-backface-visibility:hidden;border-radius:var(--radius-lg);border:1px solid var(--border);background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:18px 18px 16px;text-align:center;user-select:none;overflow:hidden}
.card-back{transform:rotateY(180deg);background:var(--bg2)}
.card-tag{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;margin-bottom:14px;max-width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.card-word{font-size:clamp(22px,5.5vw,34px);font-weight:800;margin-bottom:8px;line-height:1.2;word-break:break-word}
.card-phonetic{font-size:14px;color:var(--text2);margin-bottom:6px}
.card-hint{font-size:12px;color:var(--text3);margin-top:auto;padding-top:8px}
.card-translation{font-size:clamp(17px,4.5vw,24px);font-weight:700;margin-bottom:10px;line-height:1.4;word-break:break-word;color:var(--text)}
.card-example{font-size:15px;color:var(--text2);font-style:italic;line-height:1.7;margin-top:10px;padding:0 4px}
.card-type-badge{font-size:11px;padding:3px 10px;border-radius:20px;margin-bottom:10px;font-weight:600}
.tb-noun{background:#E1F5EE;color:#0F6E56}.tb-verb{background:#EEF2FF;color:#3B5BDB}.tb-adj{background:#FFF9DB;color:#854F0B}.tb-adv{background:#F8F0FC;color:#862E9C}.tb-phrase{background:#E7F5FF;color:#1864AB}.tb-error{background:var(--red-light);color:var(--red)}
.card-status{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;position:absolute;top:12px;right:12px;font-size:12px;font-weight:700}
.cs-known{background:var(--green-light);color:var(--green)}.cs-hard{background:var(--orange-light);color:var(--orange)}.cs-no{background:var(--red-light);color:var(--red)}

/* ── CARD ACTIONS ── */
.action-wrap{display:flex;flex-direction:column;gap:10px}
.reveal-btn{width:100%;padding:15px;border-radius:var(--radius-lg);border:1px solid var(--border2);background:var(--bg);color:var(--text);font-size:16px;font-weight:500;cursor:pointer;transition:background .15s;-webkit-tap-highlight-color:transparent}
.reveal-btn:active{background:var(--bg2)}
.rate-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.rate-btn{padding:14px 6px;border-radius:var(--radius-lg);border:1.5px solid transparent;font-size:14px;font-weight:600;cursor:pointer;transition:all .15s;display:flex;flex-direction:column;align-items:center;gap:4px;-webkit-tap-highlight-color:transparent}
.rate-btn:active{transform:scale(.96)}
.rate-btn .rb-icon{font-size:20px}
.rate-btn .rb-label{font-size:11px;font-weight:500;opacity:.85}
.rb-no{background:var(--red-light);border-color:#FFC9C9;color:var(--red)}.rb-hard{background:var(--orange-light);border-color:#FFE066;color:var(--orange)}.rb-yes{background:var(--green-light);border-color:#B2F2BB;color:var(--green)}
.nav-row{display:flex;justify-content:space-between}
.nav-btn{font-size:14px;padding:10px 18px;border-radius:var(--radius);border:1px solid var(--border2);background:var(--bg);color:var(--text2);cursor:pointer;-webkit-tap-highlight-color:transparent;font-weight:500}
.nav-btn:disabled{opacity:.3;cursor:default}
.nav-btn:active:not(:disabled){background:var(--bg2)}

/* ── QUIZ ── */
.quiz-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px}
.quiz-score-pill{font-size:13px;font-weight:600;color:var(--text2);background:var(--bg);border:1px solid var(--border);border-radius:20px;padding:5px 12px}
.quiz-score-pill span{color:var(--accent)}
.quiz-type-bar{display:flex;gap:6px;margin-bottom:12px;overflow-x:auto;padding-bottom:4px;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.quiz-type-bar::-webkit-scrollbar{display:none}
.qtype-btn{font-size:12px;padding:6px 14px;border-radius:20px;border:1px solid var(--border2);background:var(--bg);color:var(--text2);cursor:pointer;white-space:nowrap;font-weight:500;-webkit-tap-highlight-color:transparent;flex-shrink:0}
.qtype-btn.active{background:var(--accent);border-color:var(--accent);color:#fff}
.quiz-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-lg);padding:18px;margin-bottom:12px}
.quiz-meta{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px;display:flex;justify-content:space-between;gap:8px}
.quiz-prompt{font-size:16px;line-height:1.75;color:var(--text);margin-bottom:16px;white-space:pre-wrap;word-break:break-word}
.quiz-prompt .blank{display:inline-block;min-width:70px;border-bottom:2.5px solid var(--accent);color:var(--accent);font-weight:700;text-align:center;padding:0 4px}

/* Multiple choice */
.options-grid{display:flex;flex-direction:column;gap:9px}
.option-btn{width:100%;padding:13px 16px;border-radius:var(--radius);border:1.5px solid var(--border2);background:var(--bg2);color:var(--text);font-size:15px;text-align:left;cursor:pointer;transition:all .15s;-webkit-tap-highlight-color:transparent;line-height:1.4;font-weight:500}
.option-btn:active:not(:disabled){transform:scale(.98)}
.option-btn.correct{background:var(--green-light);border-color:#B2F2BB;color:var(--green)}
.option-btn.wrong{background:var(--red-light);border-color:#FFC9C9;color:var(--red)}
.option-btn:disabled{cursor:default;transform:none}

/* Type-in */
.type-in-wrap{display:flex;flex-direction:column;gap:10px}
.type-in-input{width:100%;padding:14px 16px;border-radius:var(--radius);border:2px solid var(--border2);background:var(--bg);color:var(--text);font-size:16px;outline:none;transition:border-color .15s;-webkit-appearance:none}
.type-in-input:focus{border-color:var(--accent)}
.type-in-input.correct{border-color:var(--green);background:var(--green-light);color:var(--green)}
.type-in-input.wrong{border-color:var(--red);background:var(--red-light);color:var(--red)}
.check-btn{width:100%;padding:14px;border-radius:var(--radius);border:none;background:var(--accent);color:#fff;font-size:16px;font-weight:600;cursor:pointer;-webkit-tap-highlight-color:transparent}
.check-btn:active{opacity:.88}
.check-btn:disabled{opacity:.4;cursor:default}

/* Match pairs */
.match-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:12px}
.match-col{display:flex;flex-direction:column;gap:8px}
.match-item{padding:12px 14px;border-radius:var(--radius);border:1.5px solid var(--border2);background:var(--bg2);color:var(--text);font-size:14px;cursor:pointer;transition:all .15s;-webkit-tap-highlight-color:transparent;text-align:center;line-height:1.4;font-weight:500;word-break:break-word}
.match-item.selected{border-color:var(--accent);background:var(--accent-light);color:var(--accent)}
.match-item.matched{border-color:var(--green);background:var(--green-light);color:var(--green);cursor:default}
.match-item.wrong-flash{border-color:var(--red);background:var(--red-light)}

/* Explanation */
.explanation-box{padding:14px 16px;border-radius:var(--radius);border-left:4px solid var(--accent);background:var(--accent-light);font-size:14px;line-height:1.65;color:var(--text);margin-top:12px}
.explanation-box.loading{color:var(--text3);border-color:var(--border2);background:var(--bg2);font-style:italic}
.explanation-box.wrong-ex{border-color:var(--red);background:var(--red-light)}
.ex-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;opacity:.8}
.quiz-next-btn{width:100%;padding:14px;border-radius:var(--radius-lg);border:none;background:var(--accent);color:#fff;font-size:16px;font-weight:600;cursor:pointer;margin-top:12px;-webkit-tap-highlight-color:transparent;display:none}
.quiz-next-btn.visible{display:block}
.quiz-next-btn:active{opacity:.88}


/* ── VERBOS ── */
.verb-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-lg);padding:18px;margin-bottom:12px}
.verb-infinitive{font-size:30px;font-weight:800;color:var(--accent);margin-bottom:4px;line-height:1.2}
.verb-translation{font-size:15px;color:var(--text3);margin-bottom:18px}
.verb-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:8px}
.verb-input-wrap{display:flex;flex-direction:column;gap:4px}
.verb-label{font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.05em}
.verb-input{width:100%;padding:12px 14px;border-radius:var(--radius);border:2px solid var(--border2);background:var(--bg);color:var(--text);font-size:16px;outline:none;transition:border-color .15s;-webkit-appearance:none;font-weight:600}
.verb-input:focus{border-color:var(--accent)}
.verb-input.correct{border-color:var(--green);background:var(--green-light);color:var(--green)}
.verb-input.wrong{border-color:var(--red);background:var(--red-light);color:var(--red)}
.verb-input.revealed{border-color:var(--accent);background:var(--accent-light);color:var(--accent);font-weight:700}
.verb-example{font-size:13px;color:var(--text2);font-style:italic;line-height:1.6;margin-top:8px;padding:8px 12px;background:var(--bg2);border-radius:8px}
.verb-check-btn{width:100%;padding:14px;border-radius:var(--radius);border:none;background:var(--accent);color:#fff;font-size:16px;font-weight:600;cursor:pointer;-webkit-tap-highlight-color:transparent;margin-top:10px}
.verb-check-btn:active{opacity:.88}
.verb-check-btn:disabled{opacity:.4;cursor:default}
.verb-mode-bar{display:flex;gap:6px;margin-bottom:12px;overflow-x:auto;padding-bottom:4px;scrollbar-width:none}
.verb-mode-bar::-webkit-scrollbar{display:none}

/* ── COLLOCATIONS ── */
.coll-mode-bar{display:flex;gap:6px;margin-bottom:12px;overflow-x:auto;padding-bottom:4px;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.coll-mode-bar::-webkit-scrollbar{display:none}
.coll-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px}
.coll-score-pill{font-size:13px;font-weight:600;color:var(--text2);background:var(--bg);border:1px solid var(--border);border-radius:20px;padding:5px 12px}
.coll-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px;margin-bottom:12px}
.coll-base{font-size:34px;font-weight:800;color:var(--accent);margin-bottom:6px;line-height:1.1;word-break:break-word}
.coll-hint{font-size:14px;color:var(--text3);margin-bottom:16px}
.coll-error-badge{font-size:12px;padding:4px 10px;background:var(--red-light);color:var(--red);border-radius:8px;display:inline-block;margin-top:10px}
.coll-correct{font-size:15px;padding:12px 14px;background:var(--green-light);color:var(--green);border-radius:var(--radius);border-left:4px solid #B2F2BB;font-weight:600;margin-bottom:10px}
.coll-example{font-size:14px;color:var(--text2);font-style:italic;line-height:1.6;margin-top:8px}
.nat-pair{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px}
.nat-btn{padding:16px 10px;border-radius:var(--radius);border:1.5px solid var(--border2);background:var(--bg2);color:var(--text);font-size:15px;font-weight:600;cursor:pointer;text-align:center;-webkit-tap-highlight-color:transparent;transition:all .15s;line-height:1.4;word-break:break-word}
.nat-btn:active{transform:scale(.97)}
.nat-btn.nat-correct{background:var(--green-light);border-color:#B2F2BB;color:var(--green)}
.nat-btn.nat-wrong{background:var(--red-light);border-color:#FFC9C9;color:var(--red)}

/* ── REWRITING ── */
.rw-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-lg);padding:18px;margin-bottom:12px}
.rw-original{font-size:16px;line-height:1.7;color:var(--text);padding:12px 14px;background:var(--bg2);border-radius:var(--radius);margin-bottom:14px;border-left:4px solid var(--border2)}
.rw-keyword{display:inline-block;font-size:13px;font-weight:700;color:var(--accent);background:var(--accent-light);padding:4px 12px;border-radius:8px;margin-bottom:14px}
.rw-input{width:100%;padding:14px 16px;border-radius:var(--radius);border:2px solid var(--border2);background:var(--bg);color:var(--text);font-size:16px;outline:none;transition:border-color .15s;-webkit-appearance:none}
.rw-input:focus{border-color:var(--accent)}
.rw-input.rw-correct{border-color:var(--green);background:var(--green-light);color:var(--green)}
.rw-input.rw-wrong{border-color:var(--red)}
.rw-check-btn{width:100%;padding:14px;border-radius:var(--radius);border:none;background:var(--accent);color:#fff;font-size:16px;font-weight:600;cursor:pointer;-webkit-tap-highlight-color:transparent;margin-top:10px}
.rw-check-btn:active{opacity:.88}
.rw-check-btn:disabled{opacity:.4;cursor:default}
.rw-answer-reveal{padding:12px 14px;background:var(--green-light);color:var(--green);border-radius:var(--radius);border-left:4px solid #B2F2BB;font-size:15px;font-weight:600;margin-top:10px;line-height:1.5}
.rw-ai-feedback{padding:14px 16px;border-radius:var(--radius);border-left:4px solid var(--accent);background:var(--accent-light);font-size:14px;line-height:1.65;color:var(--text);margin-top:12px}
.rw-ai-feedback.loading{color:var(--text3);border-color:var(--border2);background:var(--bg2);font-style:italic}

/* ── ERROR DETECTION ── */
.detect-sentence{font-size:18px;line-height:1.8;color:var(--text);padding:16px;background:var(--bg2);border-radius:var(--radius-lg);margin-bottom:16px;cursor:pointer;-webkit-tap-highlight-color:transparent;border:2px solid var(--border2);transition:border-color .15s;word-break:break-word}
.detect-sentence:active{border-color:var(--accent)}
.detect-sentence .err-word{cursor:pointer;border-bottom:2px dashed var(--orange);padding-bottom:1px;transition:all .15s}
.detect-sentence .err-word:hover,.detect-sentence .err-word.tapped{background:var(--orange-light);border-radius:4px;padding:0 3px}
.detect-sentence .err-word.found{background:var(--red-light);color:var(--red);border-bottom-color:var(--red);border-radius:4px;padding:0 3px;font-weight:700}
.detect-sentence .err-word.missed{background:var(--orange-light);color:var(--orange);border-radius:4px;padding:0 3px;font-weight:700}
.detect-correct{background:var(--green-light);border:1.5px solid #B2F2BB;border-radius:var(--radius-lg);padding:12px 16px;font-size:15px;color:var(--green);font-weight:600;margin-bottom:10px;line-height:1.5}
.detect-hint{font-size:13px;color:var(--text3);text-align:center;margin-bottom:8px}
.detect-give-up{width:100%;padding:10px;border-radius:var(--radius);border:1px solid var(--border2);background:transparent;color:var(--text3);font-size:13px;cursor:pointer;margin-top:8px;-webkit-tap-highlight-color:transparent}

/* ── SPACED REPETITION BADGE ── */
.sr-badge{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:700;padding:3px 8px;border-radius:20px;margin-left:6px}
.sr-due{background:var(--red-light);color:var(--red)}
.sr-soon{background:var(--orange-light);color:var(--orange)}
.sr-ok{background:var(--green-light);color:var(--green)}
.sr-banner{background:var(--accent-light);border:1px solid var(--accent);border-radius:var(--radius-lg);padding:12px 16px;margin-bottom:14px;font-size:14px;color:var(--accent);font-weight:500;display:flex;align-items:center;gap:10px}
.sr-banner b{font-weight:700}

/* ── SPEAKING ── */
.speaking-q{font-size:17px;font-weight:600;line-height:1.6;color:var(--text);padding:18px;background:var(--bg2);border-radius:var(--radius-lg);margin-bottom:16px;border-left:4px solid var(--accent)}
.speaking-context{font-size:13px;color:var(--text2);margin-bottom:16px;padding:10px 14px;background:var(--bg3);border-radius:var(--radius);line-height:1.6}
.speaking-tips{display:flex;flex-direction:column;gap:6px;margin-bottom:16px}
.speaking-tip{font-size:12px;color:var(--text3);padding:6px 10px;background:var(--bg2);border-radius:8px;border-left:3px solid var(--border2)}
.speaking-input{width:100%;padding:14px 16px;border-radius:var(--radius);border:2px solid var(--border2);background:var(--bg);color:var(--text);font-size:15px;outline:none;transition:border-color .15s;-webkit-appearance:none;min-height:120px;resize:vertical;line-height:1.6}
.speaking-input:focus{border-color:var(--accent)}
.speaking-submit{width:100%;padding:14px;border-radius:var(--radius-lg);border:none;background:var(--accent);color:#fff;font-size:16px;font-weight:600;cursor:pointer;margin-top:10px;-webkit-tap-highlight-color:transparent}
.speaking-submit:active{opacity:.88}
.speaking-submit:disabled{opacity:.4;cursor:default}
.speaking-feedback{padding:16px;border-radius:var(--radius-lg);border:1px solid var(--border);background:var(--bg);margin-top:14px}
.sf-score{display:flex;gap:10px;margin-bottom:14px;flex-wrap:wrap}
.sf-pill{font-size:12px;font-weight:700;padding:5px 12px;border-radius:20px;background:var(--bg2);color:var(--text2)}
.sf-pill.good{background:var(--green-light);color:var(--green)}
.sf-pill.ok{background:var(--orange-light);color:var(--orange)}
.sf-pill.bad{background:var(--red-light);color:var(--red)}
.sf-section{margin-bottom:14px}
.sf-section-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text3);margin-bottom:6px}
.sf-text{font-size:14px;line-height:1.7;color:var(--text2)}
.sf-phrases{display:flex;flex-direction:column;gap:8px;margin-top:8px}
.sf-phrase{font-size:14px;padding:10px 14px;background:var(--green-light);color:var(--green);border-radius:var(--radius);border-left:3px solid #B2F2BB;font-style:italic}
.speaking-filter-bar{display:flex;gap:6px;margin-bottom:12px;overflow-x:auto;padding-bottom:4px;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.speaking-filter-bar::-webkit-scrollbar{display:none}

/* ── THEORY ── */
.theory-section{margin-bottom:10px}
.theory-header{width:100%;display:flex;align-items:center;justify-content:space-between;padding:14px 16px;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-lg);cursor:pointer;-webkit-tap-highlight-color:transparent;text-align:left;gap:12px}
.theory-header.open{border-radius:var(--radius-lg) var(--radius-lg) 0 0;border-bottom-color:transparent}
.theory-title{font-size:15px;font-weight:600;color:var(--text)}
.theory-subtitle{font-size:12px;color:var(--text2);margin-top:2px}
.theory-arrow{font-size:13px;color:var(--text3);transition:transform .2s;flex-shrink:0}
.theory-header.open .theory-arrow{transform:rotate(180deg)}
.theory-body{display:none;background:var(--bg);border:1px solid var(--border);border-top:none;border-radius:0 0 var(--radius-lg) var(--radius-lg);padding:16px}
.theory-body.open{display:block}
.theory-rule{margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid var(--border)}
.theory-rule:last-child{margin-bottom:0;padding-bottom:0;border-bottom:none}
.rule-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:7px;padding:3px 8px;border-radius:6px;display:inline-block}
.rule-label.good{color:var(--green);background:var(--green-light)}.rule-label.bad{color:var(--red);background:var(--red-light)}.rule-label.tip{color:var(--accent);background:var(--accent-light)}.rule-label.neutral{color:var(--text2);background:var(--bg2)}
.rule-text{font-size:14px;line-height:1.7;color:var(--text2);margin-bottom:8px}
.rule-example{font-size:14px;margin-top:7px;padding:10px 14px;border-radius:var(--radius);line-height:1.65;white-space:pre-wrap;word-break:break-word}
.rule-example.good-ex{background:var(--green-light);color:var(--green);border-left:3px solid #B2F2BB}
.rule-example.bad-ex{background:var(--red-light);color:var(--red);border-left:3px solid #FFC9C9}
.rule-example.tip-ex{background:var(--accent-light);color:var(--accent);border-left:3px solid #74C0FC}

/* ── SHARED ── */
.empty-state{text-align:center;padding:48px 20px;color:var(--text2);font-size:15px;line-height:1.8}
.empty-state .big{font-size:48px;margin-bottom:14px}
.toast{position:fixed;bottom:calc(env(safe-area-inset-bottom,0px) + 20px);left:50%;transform:translateX(-50%);background:#1a1a1a;color:white;font-size:14px;padding:10px 20px;border-radius:24px;opacity:0;transition:opacity .3s;pointer-events:none;z-index:999;white-space:nowrap;max-width:90vw;overflow:hidden;text-overflow:ellipsis}
.toast.show{opacity:1}
.round-done{text-align:center;padding:40px 20px;background:var(--bg);border-radius:var(--radius-lg);border:1px solid var(--border)}
.round-done .big{font-size:48px;margin-bottom:12px}
.round-done h2{font-size:20px;font-weight:700;margin-bottom:8px}
.round-done p{font-size:15px;color:var(--text2);margin-bottom:20px;line-height:1.6}
.repeat-btn{display:block;width:100%;padding:15px;border-radius:var(--radius-lg);border:none;background:var(--accent);color:#fff;font-size:16px;font-weight:600;cursor:pointer;-webkit-tap-highlight-color:transparent}
.repeat-btn:active{opacity:.88}
</style>
</head>
<body>
<div class="app">

<div class="header">
  <h1>English C1</h1>
  <button class="reset-btn" onclick="confirmReset()">↺ Reset</button>
</div>

<div class="tabs">
  <button class="tab-btn active" onclick="switchTab('flashcards')"><span class="tab-icon">📚</span>Vocab</button>
  <button class="tab-btn"        onclick="switchTab('errors')"><span class="tab-icon">❌</span>Errores</button>
  <button class="tab-btn"        onclick="switchTab('collocations')"><span class="tab-icon">🔗</span>Colocac.</button>
  <button class="tab-btn"        onclick="switchTab('rewriting')"><span class="tab-icon">✍️</span>Rewrite</button>
  <button class="tab-btn"        onclick="switchTab('detect')"><span class="tab-icon">🔍</span>Detecta</button>
  <button class="tab-btn"        onclick="switchTab('speaking')"><span class="tab-icon">🗣️</span>Speaking</button>
  <button class="tab-btn"        onclick="switchTab('irregulars')"><span class="tab-icon">🔤</span>Verbos</button>
  <button class="tab-btn"        onclick="switchTab('grammar')"><span class="tab-icon">✏️</span>Quiz</button>
  <button class="tab-btn"        onclick="switchTab('theory')"><span class="tab-icon">📖</span>Teoría</button>
</div>

<!-- ══ VOCAB ══ -->
<div class="tab-content active" id="tab-flashcards">
  <div id="sr-banner" style="display:none" class="sr-banner">⏰ <span id="sr-banner-text">palabras pendientes de repaso</span></div>
  <div class="stats-bar">
    <div class="stats-bar-title">Progreso vocabulario</div>
    <div class="progress-track"><div class="pt-known" id="gp-known" style="width:0%"></div><div class="pt-hard" id="gp-hard" style="width:0%"></div><div class="pt-no" id="gp-no" style="width:0%"></div></div>
    <div class="stats-nums">
      <div class="sn"><div class="sn-dot" style="background:#2F9E44"></div><b id="g-known">0</b> sabidas</div>
      <div class="sn"><div class="sn-dot" style="background:#E67700"></div><b id="g-hard">0</b> difíciles</div>
      <div class="sn"><div class="sn-dot" style="background:#E03131"></div><b id="g-no">0</b> no sé</div>
      <div class="sn"><div class="sn-dot" style="background:var(--bg3);border:1px solid var(--border2)"></div><b id="g-new">0</b> nuevas</div>
      <div class="sn" style="margin-left:auto"><b id="g-total">0</b> total</div>
    </div>
  </div>
  <div class="mode-bar" style="grid-template-columns:repeat(4,1fr)">
    <button class="mode-btn active" data-mode="all"    onclick="setMode('all')">Todo<span class="count" id="mc-all"></span></button>
    <button class="mode-btn"        data-mode="due"    onclick="setMode('due')">Hoy<span class="count" id="mc-due"></span></button>
    <button class="mode-btn"        data-mode="hard"   onclick="setMode('hard')">Fallos<span class="count" id="mc-hard"></span></button>
    <button class="mode-btn"        data-mode="review" onclick="setMode('review')">Repaso<span class="count" id="mc-review"></span></button>
  </div>
  <div class="topic-bar" id="topic-bar"></div>
  <div class="card-area" id="card-area">
    <div class="empty-state"><div class="big">📚</div>Cargando vocabulario...</div>
  </div>
</div>

<!-- ══ ERRORS ══ -->
<div class="tab-content" id="tab-errors">
  <div class="stats-bar">
    <div class="stats-bar-title">Progreso errores</div>
    <div class="progress-track"><div class="pt-known" id="ep-known" style="width:0%"></div><div class="pt-hard" id="ep-hard" style="width:0%"></div><div class="pt-no" id="ep-no" style="width:0%"></div></div>
    <div class="stats-nums">
      <div class="sn"><div class="sn-dot" style="background:#2F9E44"></div><b id="eg-known">0</b> dominados</div>
      <div class="sn"><div class="sn-dot" style="background:#E67700"></div><b id="eg-hard">0</b> difíciles</div>
      <div class="sn"><div class="sn-dot" style="background:var(--bg3);border:1px solid var(--border2)"></div><b id="eg-new">0</b> nuevos</div>
      <div class="sn" style="margin-left:auto"><b id="eg-total">0</b> total</div>
    </div>
  </div>
  <div class="mode-bar">
    <button class="mode-btn active" data-emode="all"    onclick="setEMode('all')">Estudiar todo<span class="count" id="emc-all"></span></button>
    <button class="mode-btn"        data-emode="hard"   onclick="setEMode('hard')">Fallos<span class="count" id="emc-hard"></span></button>
    <button class="mode-btn"        data-emode="review" onclick="setEMode('review')">Repaso<span class="count" id="emc-review"></span></button>
  </div>
  <div class="topic-bar" id="error-topic-bar"></div>
  <div class="card-area" id="error-card-area">
    <div class="empty-state"><div class="big">❌</div>Cargando...</div>
  </div>
</div>

<!-- ══ COLLOCATIONS ══ -->
<div class="tab-content" id="tab-collocations">
  <div class="coll-header">
    <div class="coll-score-pill">✓ <span id="coll-score">0</span> / <span id="coll-total">—</span></div>
    <button class="nav-btn" onclick="restartCollocations()">↺ Reiniciar</button>
  </div>
  <div class="coll-mode-bar">
    <button class="qtype-btn active" data-cmode="complete" onclick="setCollMode('complete')">Completa</button>
    <button class="qtype-btn"        data-cmode="mc"       onclick="setCollMode('mc')">Opción múltiple</button>
    <button class="qtype-btn"        data-cmode="natural"  onclick="setCollMode('natural')">Natural vs Raro</button>
  </div>
  <div class="topic-bar" id="coll-topic-bar"></div>
  <div id="coll-area">
    <div class="empty-state"><div class="big">🔗</div>Cargando collocations...</div>
  </div>
</div>

<!-- ══ REWRITING ══ -->
<div class="tab-content" id="tab-rewriting">
  <div class="coll-header">
    <div class="coll-score-pill">✓ <span id="rw-score">0</span> / <span id="rw-total">—</span></div>
    <button class="nav-btn" onclick="restartRewriting()">↺ Reiniciar</button>
  </div>
  <div class="coll-mode-bar">
    <button class="qtype-btn active" data-rwfilter="all"        onclick="setRwFilter('all')">Todos</button>
    <button class="qtype-btn"        data-rwfilter="conditionals" onclick="setRwFilter('conditionals')">Conditionals</button>
    <button class="qtype-btn"        data-rwfilter="passive"    onclick="setRwFilter('passive')">Passive</button>
    <button class="qtype-btn"        data-rwfilter="modals"     onclick="setRwFilter('modals')">Modals</button>
    <button class="qtype-btn"        data-rwfilter="mixed"      onclick="setRwFilter('mixed')">Mixed</button>
  </div>
  <div id="rw-area">
    <div class="empty-state"><div class="big">✍️</div>Cargando ejercicios...</div>
  </div>
</div>

<!-- ══ ERROR DETECTION ══ -->
<div class="tab-content" id="tab-detect">
  <div class="coll-header">
    <div class="coll-score-pill">✓ <span id="det-score">0</span> / <span id="det-total">—</span></div>
    <button class="nav-btn" onclick="restartDetect()">↺ Reiniciar</button>
  </div>
  <div class="coll-mode-bar">
    <button class="qtype-btn active" data-detmode="tap"  onclick="setDetMode('tap')">Toca el error</button>
    <button class="qtype-btn"        data-detmode="mc"   onclick="setDetMode('mc')">Opción múltiple</button>
    <button class="qtype-btn"        data-detmode="correct" onclick="setDetMode('correct')">Corrige tú</button>
  </div>
  <div id="det-area">
    <div class="empty-state"><div class="big">🔍</div>Cargando...</div>
  </div>
</div>

<!-- ══ SPEAKING ══ -->
<div class="tab-content" id="tab-speaking">
  <div class="coll-header">
    <div class="coll-score-pill">Pregunta <span id="sp-current">—</span>/<span id="sp-total">—</span></div>
    <button class="nav-btn" onclick="restartSpeaking()">↺ Reiniciar</button>
  </div>
  <div class="speaking-filter-bar">
    <button class="qtype-btn active" data-spfilter="all"      onclick="setSpFilter('all')">Todos</button>
    <button class="qtype-btn"        data-spfilter="opinion"  onclick="setSpFilter('opinion')">Opinión</button>
    <button class="qtype-btn"        data-spfilter="compare"  onclick="setSpFilter('compare')">Comparar</button>
    <button class="qtype-btn"        data-spfilter="problem"  onclick="setSpFilter('problem')">Problema</button>
    <button class="qtype-btn"        data-spfilter="describe" onclick="setSpFilter('describe')">Describir</button>
  </div>
  <div id="sp-area">
    <div class="empty-state"><div class="big">🗣️</div>Cargando preguntas...</div>
  </div>
</div>


<!-- ══ VERBS ══ -->
<div class="tab-content" id="tab-verbs">
  <div class="coll-header">
    <div class="coll-score-pill">✓ <span id="verb-score">0</span> / <span id="verb-total">—</span></div>
    <button class="nav-btn" onclick="restartVerbs()">↺ Reiniciar</button>
  </div>
  <div class="verb-mode-bar">
    <button class="qtype-btn active" data-vmode="all"        onclick="setVerbMode('all')">Todos</button>
    <button class="qtype-btn"        data-vmode="common"     onclick="setVerbMode('common')">Frecuentes</button>
    <button class="qtype-btn"        data-vmode="aaa"        onclick="setVerbMode('aaa')">A-A-A</button>
    <button class="qtype-btn"        data-vmode="abb"        onclick="setVerbMode('abb')">A-B-B</button>
    <button class="qtype-btn"        data-vmode="abc"        onclick="setVerbMode('abc')">A-B-C</button>
    <button class="qtype-btn"        data-vmode="typein"     onclick="setVerbMode('typein')">Escribe</button>
    <button class="qtype-btn"        data-vmode="mc"         onclick="setVerbMode('mc')">Opción múltiple</button>
  </div>
  <div id="verb-area">
    <div class="empty-state"><div class="big">🔤</div>Cargando verbos...</div>
  </div>
</div>

<!-- ══ QUIZ ══ -->
<div class="tab-content" id="tab-grammar">
  <div class="quiz-header">
    <div class="quiz-score-pill">Pregunta <span id="q-current">—</span>/<span id="q-total">—</span> · ✓ <span id="q-score">0</span></div>
    <button class="nav-btn" onclick="restartQuiz()">↺ Reiniciar</button>
  </div>
  <div class="quiz-type-bar">
    <button class="qtype-btn active" data-qtype="all"      onclick="setQuizType('all')">Todos</button>
    <button class="qtype-btn"        data-qtype="mc"       onclick="setQuizType('mc')">Opción múltiple</button>
    <button class="qtype-btn"        data-qtype="typein"   onclick="setQuizType('typein')">Escribe</button>
    <button class="qtype-btn"        data-qtype="match"    onclick="setQuizType('match')">Empareja</button>
  </div>
  <div class="quiz-filter-bar" id="quiz-filter-bar" style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px"></div>
  <div id="quiz-area">
    <div class="empty-state"><div class="big">✏️</div>Cargando ejercicios...</div>
  </div>
</div>

<!-- ══ THEORY ══ -->
<div class="tab-content" id="tab-theory">
  <div id="theory-content"></div>
</div>

</div>
<div class="toast" id="toast"></div>

<script>
const PROGRESS_KEY='vocab_progress_v2',EPROGRESS_KEY='error_progress_v1',VOCAB_KEY='vocab_data_v2',EXER_KEY='exercises_data_v1';

/* ── UTILS ── */
function switchTab(tab){
  const map={flashcards:0,errors:1,collocations:2,rewriting:3,detect:4,speaking:5,irregulars:6,grammar:7,theory:8};
  document.querySelectorAll('.tab-btn').forEach((b,i)=>b.classList.toggle('active',i===map[tab]));
  document.querySelectorAll('.tab-content').forEach((c,i)=>c.classList.toggle('active',i===map[tab]));
  if(tab==='flashcards') renderSRBanner();
}
function showToast(msg){
  const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2200);
}
function shuffle(arr){const a=[...arr];for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}
function confirmReset(){
  if(!confirm('¿Borrar todo el progreso?'))return;
  progress={};eprogress={};quizScore=0;
  try{localStorage.removeItem(PROGRESS_KEY);localStorage.removeItem(EPROGRESS_KEY);}catch(e){}
  updateGlobalStats();updateModeCounts();renderCard();
  updateErrorStats();updateEModeCounts();renderErrorCard();
  document.getElementById('q-score').textContent='0';
  showToast('Progreso borrado');
}

/* ── VOCAB FLASHCARDS ── */
let vocab=[],progress={},currentDeck=[],currentIdx=0,currentMode='all',currentTopic='all',flipped=false;

function loadProgress(){try{progress=JSON.parse(localStorage.getItem(PROGRESS_KEY)||'{}');}catch(e){progress={};}}
function saveProgress(){try{localStorage.setItem(PROGRESS_KEY,JSON.stringify(progress));}catch(e){}}
function saveVocab(d){try{localStorage.setItem(VOCAB_KEY,JSON.stringify(d));}catch(e){}}
function loadSavedVocab(){try{const d=localStorage.getItem(VOCAB_KEY);return d?JSON.parse(d):null;}catch(e){return null;}}

function loadData(data){
  const all=data.vocabulary||(Array.isArray(data)?data:[]);
  vocab=all.filter(v=>v.type!=='error');
  errorVocab=all.filter(v=>v.type==='error');
  saveVocab(data);
  buildTopics();updateGlobalStats();updateDeck();
  buildErrorTopics();updateErrorStats();updateEModeCounts();updateEDeck();
  buildVocabQuizzes();
}

function buildVocabQuizzes(){
  // Generate quiz exercises from vocab JSON
  if(!vocab.length)return;
  const vocabExercises=[];
  const shuffled=shuffle([...vocab]);
  shuffled.forEach(v=>{
    if(!v.word||!v.translation)return;
    // Exercise 1: word → translation (type-in)
    vocabExercises.push({
      topic: v.topic||'Vocabulary',
      prompt: `¿Qué significa "${v.word}"?`,
      answer: v.translation.split('/')[0].trim(),
      distractors: shuffle(vocab.filter(o=>o.word!==v.word&&o.translation)).slice(0,3).map(o=>o.translation.split('/')[0].trim()),
      explanation: v.example ? 'Ejemplo: "' + v.example + '"' : '',
      source:'vocab'
    });
    // Exercise 2: translation → word (type-in, for phrases/patterns)
    if(v.example){
      const exWithBlank=v.example.replace(new RegExp(v.word.replace(/[-[\]{}()*+?.,\\^$|#\s]/g,'\\$&'),'i'),'___');
      if(exWithBlank!==v.example){
        vocabExercises.push({
          topic: v.topic||'Vocabulary',
          prompt: `Completa la frase:\n${exWithBlank}`,
          answer: v.word,
          distractors: shuffle(vocab.filter(o=>o.word!==v.word)).slice(0,3).map(o=>o.word),
          explanation: v.translation + (v.example ? ' | "' + v.example + '"' : ''),
          source:'vocab'
        });
      }
    }
  });
  // Merge with existing exercises from JSON, vocab ones first when filtering by vocab topic
  vocabExercisesCache=vocabExercises;
  // Rebuild quiz if it's on vocab mode
  if(quizTopic!=='all'){buildQuizFilters();restartQuiz();}
}

function buildTopics(){
  const topics=['all',...new Set(vocab.map(v=>v.topic).filter(Boolean))];
  document.getElementById('topic-bar').innerHTML=topics.map(t=>
    `<button class="topic-btn${t===currentTopic?' active':''}" onclick="setTopic('${t}')">${t==='all'?'Todos':t}</button>`
  ).join('');
}
function setTopic(t){currentTopic=t;buildTopics();updateDeck();}
function setMode(m){
  currentMode=m;
  document.querySelectorAll('[data-mode]').forEach(b=>b.classList.toggle('active',b.dataset.mode===m));
  updateDeck();
}
function filteredVocab(){return currentTopic==='all'?vocab:vocab.filter(v=>v.topic===currentTopic);}
function updateDeck(){
  const base=filteredVocab();
  if(currentMode==='hard')        currentDeck=shuffle(base.filter(v=>progress[v.word]==='hard'||progress[v.word]==='no'));
  else if(currentMode==='review') currentDeck=shuffle(base.filter(v=>progress[v.word]==='known'));
  else{
    const no=shuffle(base.filter(v=>progress[v.word]==='no'));
    const hard=shuffle(base.filter(v=>progress[v.word]==='hard'));
    const unseen=shuffle(base.filter(v=>!progress[v.word]));
    const known=shuffle(base.filter(v=>progress[v.word]==='known'));
    currentDeck=[...no,...hard,...unseen,...known];
  }
  currentIdx=0;flipped=false;updateModeCounts();renderCard();
}
function updateGlobalStats(){
  const total=vocab.length,known=vocab.filter(v=>progress[v.word]==='known').length,
        hard=vocab.filter(v=>progress[v.word]==='hard').length,no=vocab.filter(v=>progress[v.word]==='no').length;
  document.getElementById('g-total').textContent=total;
  document.getElementById('g-known').textContent=known;
  document.getElementById('g-hard').textContent=hard;
  document.getElementById('g-no').textContent=no;
  document.getElementById('g-new').textContent=total-known-hard-no;
  const pct=n=>total?Math.round((n/total)*100)+'%':'0%';
  document.getElementById('gp-known').style.width=pct(known);
  document.getElementById('gp-hard').style.width=pct(hard);
  document.getElementById('gp-no').style.width=pct(no);
}
function updateModeCounts(){
  const base=filteredVocab();
  document.getElementById('mc-all').textContent='\n'+base.length+' cards';
  document.getElementById('mc-hard').textContent='\n'+base.filter(v=>progress[v.word]==='hard'||progress[v.word]==='no').length+' cards';
  document.getElementById('mc-review').textContent='\n'+base.filter(v=>progress[v.word]==='known').length+' cards';
}
function tbClass(t){return({verb:'tb-verb',noun:'tb-noun',adj:'tb-adj',adv:'tb-adv',phrase:'tb-phrase',error:'tb-error'}[t]||'tb-noun');}
function tbName(t){return({verb:'verbo',noun:'sustantivo',adj:'adjetivo',adv:'adverbio',phrase:'frase',error:'error común'}[t]||t||'');}
function statusBadge(w,prog){
  const s=(prog||progress)[w];
  if(s==='known')return'<div class="card-status cs-known">✓</div>';
  if(s==='hard') return'<div class="card-status cs-hard">~</div>';
  if(s==='no')   return'<div class="card-status cs-no">✗</div>';
  return'';
}
function renderCard(){
  const area=document.getElementById('card-area');
  if(!currentDeck.length){
    const msgs={hard:'¡No hay palabras difíciles aquí! 🎉',review:'Aún no has acertado ninguna. ¡Ánimo!',all:vocab.length?'No hay palabras para este filtro.':'Cargando vocabulario...'};
    area.innerHTML=`<div class="empty-state"><div class="big">${currentMode==='hard'?'🎉':'📚'}</div>${msgs[currentMode]}</div>`;
    return;
  }
  const card=currentDeck[currentIdx],pct=Math.round((currentIdx/currentDeck.length)*100);
  area.innerHTML=`
    <div class="prog-row">
      <div class="prog-bar"><div class="prog-fill" style="width:${pct}%"></div></div>
      <span class="prog-label">${currentIdx+1}/${currentDeck.length}</span>
    </div>
    <div class="card-wrap" id="the-card" onclick="flipCard()">
      <div class="card-inner">
        <div class="card-face">
          ${statusBadge(card.word)}
          <div class="card-tag">${card.topic||''}</div>
          <div class="card-word">${card.word}</div>
          ${card.phonetic?`<div class="card-phonetic">${card.phonetic}</div>`:''}
          <div class="card-hint">Toca para ver la traducción</div>
        </div>
        <div class="card-face card-back">
          ${statusBadge(card.word)}
          <span class="card-type-badge ${tbClass(card.type)}">${tbName(card.type)}</span>
          <div class="card-translation">${card.translation}</div>
          ${card.example?`<div class="card-example">"${card.example}"</div>`:''}
        </div>
      </div>
    </div>
    <div class="action-wrap" id="action-area">
      <button class="reveal-btn" onclick="flipCard()">Ver traducción</button>
    </div>
    <div class="nav-row">
      <button class="nav-btn" onclick="prevCard()" ${currentIdx===0?'disabled':''}>← Anterior</button>
      <button class="nav-btn" onclick="nextCard()" ${currentIdx===currentDeck.length-1?'disabled':''}>Siguiente →</button>
    </div>`;
}
function flipCard(){
  const wrap=document.getElementById('the-card');if(!wrap)return;
  flipped=!flipped;wrap.classList.toggle('flipped',flipped);
  document.getElementById('action-area').innerHTML=flipped
    ?`<div class="rate-row">
        <button class="rate-btn rb-no"   onclick="rate('no')"><span class="rb-icon">✗</span><span class="rb-label">No sé</span></button>
        <button class="rate-btn rb-hard" onclick="rate('hard')"><span class="rb-icon">〜</span><span class="rb-label">Difícil</span></button>
        <button class="rate-btn rb-yes"  onclick="rate('known')"><span class="rb-icon">✓</span><span class="rb-label">Lo sé</span></button>
       </div>`
    :`<button class="reveal-btn" onclick="flipCard()">Ver traducción</button>`;
}
function rate(val){
  const word=currentDeck[currentIdx] && currentDeck[currentIdx].word;
  if(word){
    progress[word]=val;
    srRate(word,val);
  }
  saveProgress();updateGlobalStats();updateModeCounts();
  setTimeout(()=>{
    if(currentIdx<currentDeck.length-1){currentIdx++;flipped=false;renderCard();}
    else{
      const known=vocab.filter(v=>progress[v.word]==='known').length;
      document.getElementById('card-area').innerHTML=`
        <div class="round-done">
          <div class="big">🎯</div>
          <h2>¡Ronda completada!</h2>
          <p>${known} de ${vocab.length} palabras dominadas en total.</p>
          <button class="repeat-btn" onclick="updateDeck()">↺ Repetir</button>
        </div>`;
    }
  },200);
}
function nextCard(){if(currentIdx<currentDeck.length-1){currentIdx++;flipped=false;renderCard();}}
function prevCard(){if(currentIdx>0){currentIdx--;flipped=false;renderCard();}}

/* ── ERROR FLASHCARDS ── */
let errorVocab=[],eprogress={},eDeck=[],eIdx=0,eMode='all',eTopic='all',eFlipped=false;
function loadEProgress(){try{eprogress=JSON.parse(localStorage.getItem(EPROGRESS_KEY)||'{}');}catch(e){eprogress={};}}
function saveEProgress(){try{localStorage.setItem(EPROGRESS_KEY,JSON.stringify(eprogress));}catch(e){}}
function buildErrorTopics(){
  const topics=['all',...new Set(errorVocab.map(v=>v.topic).filter(Boolean))];
  document.getElementById('error-topic-bar').innerHTML=topics.map(t=>
    `<button class="topic-btn${t===eTopic?' active':''}" onclick="setETopic('${t}')">${t==='all'?'Todos':t}</button>`
  ).join('');
}
function setETopic(t){eTopic=t;buildErrorTopics();updateEDeck();}
function setEMode(m){
  eMode=m;
  document.querySelectorAll('[data-emode]').forEach(b=>b.classList.toggle('active',b.dataset.emode===m));
  updateEDeck();
}
function filteredErrors(){return eTopic==='all'?errorVocab:errorVocab.filter(v=>v.topic===eTopic);}
function updateEDeck(){
  const base=filteredErrors();
  if(eMode==='hard')        eDeck=shuffle(base.filter(v=>eprogress[v.word]==='hard'||eprogress[v.word]==='no'));
  else if(eMode==='review') eDeck=shuffle(base.filter(v=>eprogress[v.word]==='known'));
  else{
    const no=shuffle(base.filter(v=>eprogress[v.word]==='no'));
    const hard=shuffle(base.filter(v=>eprogress[v.word]==='hard'));
    const unseen=shuffle(base.filter(v=>!eprogress[v.word]));
    const known=shuffle(base.filter(v=>eprogress[v.word]==='known'));
    eDeck=[...no,...hard,...unseen,...known];
  }
  eIdx=0;eFlipped=false;updateEModeCounts();renderErrorCard();
}
function updateErrorStats(){
  const total=errorVocab.length,known=errorVocab.filter(v=>eprogress[v.word]==='known').length,
        hard=errorVocab.filter(v=>eprogress[v.word]==='hard').length,no=errorVocab.filter(v=>eprogress[v.word]==='no').length;
  document.getElementById('eg-total').textContent=total;
  document.getElementById('eg-known').textContent=known;
  document.getElementById('eg-hard').textContent=hard;
  document.getElementById('eg-new').textContent=total-known-hard-no;
  const pct=n=>total?Math.round((n/total)*100)+'%':'0%';
  document.getElementById('ep-known').style.width=pct(known);
  document.getElementById('ep-hard').style.width=pct(hard);
  document.getElementById('ep-no').style.width=pct(no);
}
function updateEModeCounts(){
  const base=filteredErrors();
  document.getElementById('emc-all').textContent='\n'+base.length+' cards';
  document.getElementById('emc-hard').textContent='\n'+base.filter(v=>eprogress[v.word]==='hard'||eprogress[v.word]==='no').length+' cards';
  document.getElementById('emc-review').textContent='\n'+base.filter(v=>eprogress[v.word]==='known').length+' cards';
}
function renderErrorCard(){
  const area=document.getElementById('error-card-area');
  if(!eDeck.length){
    const msgs={hard:'¡No hay errores difíciles! 🎉',review:'Aún no has dominado ninguno.',all:errorVocab.length?'No hay tarjetas para este filtro.':'Sin entradas de tipo "error".'};
    area.innerHTML=`<div class="empty-state"><div class="big">${eMode==='hard'?'🎉':'❌'}</div>${msgs[eMode]}</div>`;
    return;
  }
  const card=eDeck[eIdx],pct=Math.round((eIdx/eDeck.length)*100);
  area.innerHTML=`
    <div class="prog-row">
      <div class="prog-bar"><div class="prog-fill" style="width:${pct}%"></div></div>
      <span class="prog-label">${eIdx+1}/${eDeck.length}</span>
    </div>
    <div class="card-wrap" id="the-ecard" onclick="flipECard()">
      <div class="card-inner">
        <div class="card-face">
          ${statusBadge(card.word,eprogress)}
          <div class="card-tag">${card.topic||''}</div>
          <div class="card-type-badge tb-verb" style="background:var(--green-light);color:var(--green);margin-bottom:10px">✅ forma correcta</div>
          <div class="card-word">${card.word}</div>
          ${card.example?`<div class="card-example" style="margin-top:8px">${card.example}</div>`:''}
          <div class="card-hint">Toca para ver el error típico</div>
        </div>
        <div class="card-face card-back">
          ${statusBadge(card.word,eprogress)}
          <div class="card-tag">${card.topic||''}</div>
          <div class="card-type-badge tb-error">❌ error común</div>
          <div class="card-translation" style="color:var(--red)">${card.translation}</div>
          ${card.explanation?`<div class="card-example" style="margin-top:8px;font-style:normal;color:var(--text2)">${card.explanation}</div>`:''}
        </div>
      </div>
    </div>
    <div class="action-wrap" id="eaction-area">
      <button class="reveal-btn" onclick="flipECard()">Ver el error típico</button>
    </div>
    <div class="nav-row">
      <button class="nav-btn" onclick="prevECard()" ${eIdx===0?'disabled':''}>← Anterior</button>
      <button class="nav-btn" onclick="nextECard()" ${eIdx===eDeck.length-1?'disabled':''}>Siguiente →</button>
    </div>`;
}
function flipECard(){
  const wrap=document.getElementById('the-ecard');if(!wrap)return;
  eFlipped=!eFlipped;wrap.classList.toggle('flipped',eFlipped);
  document.getElementById('eaction-area').innerHTML=eFlipped
    ?`<div class="rate-row">
        <button class="rate-btn rb-no"   onclick="rateE('no')"><span class="rb-icon">✗</span><span class="rb-label">No sé</span></button>
        <button class="rate-btn rb-hard" onclick="rateE('hard')"><span class="rb-icon">〜</span><span class="rb-label">Difícil</span></button>
        <button class="rate-btn rb-yes"  onclick="rateE('known')"><span class="rb-icon">✓</span><span class="rb-label">Lo sé</span></button>
       </div>`
    :`<button class="reveal-btn" onclick="flipECard()">Ver el error típico</button>`;
}
function rateE(val){
  eprogress[eDeck[eIdx].word]=val;saveEProgress();updateErrorStats();updateEModeCounts();
  setTimeout(()=>{
    if(eIdx<eDeck.length-1){eIdx++;eFlipped=false;renderErrorCard();}
    else{
      const known=errorVocab.filter(v=>eprogress[v.word]==='known').length;
      document.getElementById('error-card-area').innerHTML=`
        <div class="round-done">
          <div class="big">🎯</div>
          <h2>¡Ronda completada!</h2>
          <p>${known} de ${errorVocab.length} errores dominados.</p>
          <button class="repeat-btn" onclick="updateEDeck()">↺ Repetir</button>
        </div>`;
    }
  },200);
}
function nextECard(){if(eIdx<eDeck.length-1){eIdx++;eFlipped=false;renderErrorCard();}}
function prevECard(){if(eIdx>0){eIdx--;eFlipped=false;renderErrorCard();}}

/* ── QUIZ ── */
let exercises=[],vocabExercisesCache=[],quizDeck=[],quizIdx=0,quizScore=0,quizTopic='all',quizAnswered=false,quizType='all';
// match state
let matchLeft=[],matchRight=[],matchSelected=null,matchSide=null,matchCorrect=0,matchTotal=0;

function loadSavedEx(){try{const d=localStorage.getItem(EXER_KEY);return d?JSON.parse(d):null;}catch(e){return null;}}
function saveEx(d){try{localStorage.setItem(EXER_KEY,JSON.stringify(d));}catch(e){}}

function loadExercises(data){
  exercises=data.exercises||(Array.isArray(data)?data:[]);
  saveEx(data);buildQuizFilters();restartQuiz();
}
function buildQuizFilters(){
  const topics=['all',...new Set(exercises.map(e=>e.topic).filter(Boolean))];
  document.getElementById('quiz-filter-bar').innerHTML=topics.map(t=>
    `<button class="topic-btn${t===quizTopic?' active':''}" onclick="setQuizTopic('${t}')">${t==='all'?'Todos':t}</button>`
  ).join('');
}
function setQuizTopic(t){quizTopic=t;buildQuizFilters();restartQuiz();}
function setQuizType(qt){
  quizType=qt;
  document.querySelectorAll('[data-qtype]').forEach(b=>b.classList.toggle('active',b.dataset.qtype===qt));
  restartQuiz();
}
function restartQuiz(){
  // Merge grammar exercises + vocab exercises
  const grammarBase=quizTopic==='all'?exercises:exercises.filter(e=>e.topic===quizTopic);
  const vocabBase=quizTopic==='all'
    ?vocabExercisesCache
    :vocabExercisesCache.filter(e=>e.topic===quizTopic);
  // Mix: 60% grammar, 40% vocab (or all of each if small)
  const maxGrammar=Math.min(grammarBase.length,30);
  const maxVocab=Math.min(vocabBase.length,20);
  let base=[...shuffle(grammarBase).slice(0,maxGrammar),...shuffle(vocabBase).slice(0,maxVocab)];
  if(!base.length)base=quizTopic==='all'?[...exercises,...vocabExercisesCache]:[...grammarBase,...vocabBase];
  quizDeck=shuffle(base);
  quizIdx=0;quizScore=0;quizAnswered=false;
  document.getElementById('q-score').textContent='0';
  renderQuiz();
}

function getExType(ex,idx){
  if(quizType==='mc') return 'mc';
  if(quizType==='typein') return 'typein';
  if(quizType==='match') return 'match';
  // auto: alternate to keep it interesting
  if(!ex.distractors||ex.distractors.length<2) return 'typein';
  return idx%3===2?'typein':'mc';
}

function renderQuiz(){
  const area=document.getElementById('quiz-area');
  document.getElementById('q-score').textContent=quizScore;
  if(!quizDeck.length){
    document.getElementById('q-current').textContent='—';
    document.getElementById('q-total').textContent='—';
    area.innerHTML=`<div class="empty-state"><div class="big">✏️</div>Cargando ejercicios...</div>`;
    return;
  }
  if(quizIdx>=quizDeck.length){
    document.getElementById('q-current').textContent=quizDeck.length;
    document.getElementById('q-total').textContent=quizDeck.length;
    const pct=Math.round((quizScore/quizDeck.length)*100);
    area.innerHTML=`
      <div class="round-done">
        <div class="big">${pct>=70?'🎉':'💪'}</div>
        <h2>¡Test completado!</h2>
        <p>Acertaste <b>${quizScore} de ${quizDeck.length}</b> (${pct}%)</p>
        <button class="repeat-btn" onclick="restartQuiz()">↺ Repetir</button>
      </div>`;
    return;
  }

  const ex=quizDeck[quizIdx];
  const exType=(quizType==='match')?'match':getExType(ex,quizIdx);
  document.getElementById('q-current').textContent=quizIdx+1;
  document.getElementById('q-total').textContent=quizDeck.length;
  quizAnswered=false;

  if(exType==='match'){
    renderMatchRound();
  } else if(exType==='typein'){
    renderTypeIn(ex);
  } else {
    renderMC(ex);
  }
}

function renderMC(ex){
  const area=document.getElementById('quiz-area');
  const promptHtml=ex.prompt.replace(/___+/g,'<span class="blank">___</span>');
  const opts=shuffle([ex.answer,...(ex.distractors||[])]);
  area.innerHTML=`
    <div class="quiz-card">
      <div class="quiz-meta"><span>${ex.topic||''}</span><span>${ex.unit?'U'+ex.unit:''}</span></div>
      <div class="quiz-prompt">${promptHtml}</div>
      <div class="options-grid" id="options-grid">
        ${opts.map((o,i)=>`<button class="option-btn" onclick="selectMC(${i})" data-val="${encodeURIComponent(o)}">${o}</button>`).join('')}
      </div>
      <div id="explanation-area"></div>
    </div>
    <button class="quiz-next-btn" id="next-btn" onclick="nextQuestion()">Siguiente →</button>`;
}

function selectMC(idx){
  if(quizAnswered)return;
  quizAnswered=true;
  const ex=quizDeck[quizIdx];
  const btns=document.querySelectorAll('.option-btn');
  const chosen=decodeURIComponent(btns[idx].dataset.val);
  const correct=chosen===ex.answer;
  if(correct)quizScore++;
  document.getElementById('q-score').textContent=quizScore;
  btns.forEach(b=>{
    b.disabled=true;
    const v=decodeURIComponent(b.dataset.val);
    if(v===ex.answer)b.classList.add('correct');
    else if(b===btns[idx]&&!correct)b.classList.add('wrong');
  });
  const nb=document.getElementById('next-btn');if(nb)nb.classList.add('visible');
  fetchExplanation(ex,chosen,correct);
}

function renderTypeIn(ex){
  const area=document.getElementById('quiz-area');
  const promptHtml=ex.prompt.replace(/___+/g,'<span class="blank">___</span>');
  area.innerHTML=`
    <div class="quiz-card">
      <div class="quiz-meta"><span>${ex.topic||''}</span><span>${ex.unit?'U'+ex.unit:''}</span></div>
      <div class="quiz-prompt">${promptHtml}</div>
      <div class="type-in-wrap">
        <input class="type-in-input" id="type-input" type="text" placeholder="Escribe tu respuesta..." autocomplete="off" autocorrect="off" spellcheck="false" onkeydown="if(event.key==='Enter')checkTypeIn()">
        <button class="check-btn" id="check-btn" onclick="checkTypeIn()">Comprobar</button>
      </div>
      <div id="explanation-area"></div>
    </div>
    <button class="quiz-next-btn" id="next-btn" onclick="nextQuestion()">Siguiente →</button>`;
  setTimeout(()=>{const inp=document.getElementById('type-input');if(inp)inp.focus();},300);
}

function checkTypeIn(){
  if(quizAnswered)return;
  const input=document.getElementById('type-input');
  const btn=document.getElementById('check-btn');
  if(!input||!input.value.trim())return;
  quizAnswered=true;
  const ex=quizDeck[quizIdx];
  const given=normalise(input.value.trim().toLowerCase());
  // Accept any slash-separated alternative, case-insensitive
  const alternatives=ex.answer.split('/').map(a=>normalise(a.trim().toLowerCase()));
  const correct=alternatives.some(a=>given===a);
  if(correct)quizScore++;
  document.getElementById('q-score').textContent=quizScore;
  input.disabled=true;btn.disabled=true;
  input.classList.add(correct?'correct':'wrong');
  if(!correct){
    const wrap=input.parentElement;
    const hint=document.createElement('div');
    hint.style.cssText='font-size:14px;padding:10px 14px;background:var(--green-light);color:var(--green);border-radius:10px;border-left:4px solid #B2F2BB;font-weight:500;margin-top:8px';
    hint.textContent='✅ Respuesta: '+ex.answer;
    wrap.appendChild(hint);
  }
  const nb=document.getElementById('next-btn');if(nb)nb.classList.add('visible');
  fetchExplanation(ex,input.value.trim(),correct);
}

function normalise(s){return s.replace(/['']/g,"'").replace(/\s+/g,' ').trim();}

/* ── MATCH MODE ── */
function renderMatchRound(){
  const area=document.getElementById('quiz-area');
  // Take up to 4 exercises for a match round
  const start=quizIdx;
  const end=Math.min(quizIdx+4,quizDeck.length);
  const group=quizDeck.slice(start,end);
  matchTotal=group.length;
  matchCorrect=0;
  matchSelected=null;matchSide=null;

  const lefts=shuffle(group.map(e=>({id:e.answer,text:e.answer,exIdx:group.indexOf(e)})));
  const rights=shuffle(group.map(e=>({id:e.answer,text:e.prompt.replace(/\n.*/,'').substring(0,60),exIdx:group.indexOf(e)})));
  matchLeft=lefts;matchRight=rights;

  area.innerHTML=`
    <div class="quiz-card">
      <div class="quiz-meta"><span>Empareja los pares</span><span>${quizIdx+1}–${end}/${quizDeck.length}</span></div>
      <div class="quiz-prompt" style="font-size:14px;margin-bottom:10px">Relaciona cada respuesta con su ejercicio.</div>
      <div class="match-grid">
        <div class="match-col" id="match-left">
          ${lefts.map((l,i)=>`<button class="match-item" id="ml-${i}" onclick="selectMatch('left',${i})">${l.text}</button>`).join('')}
        </div>
        <div class="match-col" id="match-right">
          ${rights.map((r,i)=>`<button class="match-item" id="mr-${i}" onclick="selectMatch('right',${i})">${r.text}</button>`).join('')}
        </div>
      </div>
      <div id="explanation-area"></div>
    </div>
    <button class="quiz-next-btn" id="next-btn" onclick="nextQuestion()">Siguiente →</button`;
}

function selectMatch(side,idx){
  const el=document.getElementById('m'+side[0]+'-'+idx);
  if(!el||el.classList.contains('matched'))return;

  if(matchSide===null){
    // first selection
    matchSide=side;matchSelected=idx;
    document.querySelectorAll('.match-item').forEach(e=>e.classList.remove('selected'));
    el.classList.add('selected');
  } else if(matchSide===side){
    // same side: switch selection
    document.querySelectorAll('.match-item').forEach(e=>e.classList.remove('selected'));
    matchSide=side;matchSelected=idx;
    el.classList.add('selected');
  } else {
    // different side: check match
    const leftIdx=side==='right'?matchSelected:idx;
    const rightIdx=side==='right'?idx:matchSelected;
    const leftItem=matchLeft[leftIdx];
    const rightItem=matchRight[rightIdx];
    const correct=leftItem.id===rightItem.id;

    const lEl=document.getElementById('ml-'+leftIdx);
    const rEl=document.getElementById('mr-'+rightIdx);

    if(correct){
      lEl.classList.remove('selected');rEl.classList.remove('selected');
      lEl.classList.add('matched');rEl.classList.add('matched');
      lEl.disabled=true;rEl.disabled=true;
      matchCorrect++;
      quizScore++;
      document.getElementById('q-score').textContent=quizScore;
      if(matchCorrect===matchTotal){
        // advance past this group
        quizIdx+=matchTotal;
        setTimeout(()=>{
          const nb=document.getElementById('next-btn');
          if(nb){nb.classList.add('visible');nb.onclick=()=>renderQuiz();}
          const ea=document.getElementById('explanation-area');
          if(ea){ea.innerHTML=`<div class="explanation-box" style="margin-top:0"><div class="ex-label">✓ ¡Todos emparejados!</div>Muy bien, has completado el grupo.</div>`;}
        },300);
      }
    } else {
      lEl.classList.add('wrong-flash');rEl.classList.add('wrong-flash');
      setTimeout(()=>{
        lEl.classList.remove('wrong-flash','selected');
        rEl.classList.remove('wrong-flash','selected');
      },500);
    }
    matchSide=null;matchSelected=null;
    document.querySelectorAll('.match-item:not(.matched)').forEach(e=>e.classList.remove('selected'));
  }
}

function nextQuestion(){
  if(!quizAnswered) return;
  quizIdx++;renderQuiz();
}

function fetchExplanation(ex,chosen,correct){
  const box=document.getElementById('explanation-area');if(!box)return;
  // Use preloaded explanation — no AI needed
  const explanation=ex.explanation||'Revisa este punto en tus apuntes.';
  box.className=`explanation-box${correct?'':' wrong-ex'}`;
  box.innerHTML=`<div class="ex-label">${correct?'✓ Correcto':'✗ Incorrecto — respuesta: '+ex.answer}</div>${explanation}`;
}

/* ── THEORY ── */
const THEORY_DATA=[
  {title:'📝 Writing · Proposals',subtitle:'Estructura, errores y registro C1',sections:[
    {label:'tip',labelText:'Estructura esperada',text:'Un proposal C1 debe tener encabezados funcionales que guíen al lector. Sin encabezados o con encabezados vagos, el texto baja de nivel aunque las ideas sean buenas.',examples:[{type:'bad',text:'❌ Introduction / Things / More things'},{type:'good',text:'✅ Aim of the proposal / Current situation / Suggested measures / Conclusion'}]},
    {label:'bad',labelText:'Errores gramaticales frecuentes',text:'',examples:[{type:'bad',text:"❌ Government don't need to boost the budget\n❌ Bike's parkings makes people feel comfortable"},{type:'good',text:"✅ The government doesn't need to boost the budget\n✅ Bike parking facilities make people feel comfortable"}]},
    {label:'bad',labelText:'False friends en proposals',text:'',examples:[{type:'bad',text:'❌ upload → ✅ increase / upgrade\n❌ installation (of ideas) → ✅ implementation\n❌ economical improvement → ✅ financial benefit\n❌ formation (citizens) → ✅ training / education\n❌ ecology vehicles → ✅ eco-friendly vehicles'}]},
    {label:'bad',labelText:'Collocaciones incorrectas',text:'',examples:[{type:'bad',text:'❌ do courses to teach how to ride\n❌ boost the use of bicycles (overused)\n❌ make residents feel safe in their cycling daily trips'},{type:'good',text:'✅ offer training courses on safe cycling\n✅ encourage the use of bicycles\n✅ make residents feel safe during their daily cycling trips'}]},
    {label:'tip',labelText:'Hedging en predicciones',text:'Evita predicciones absolutas. En C1 se espera lenguaje de cautela.',examples:[{type:'bad',text:'❌ People will change their transport without a doubt.\n❌ Pollution will decrease significantly in the first year.'},{type:'good',text:'✅ This could encourage people to change their means of transport.\n✅ This may lead to a reduction in pollution over time.'}]},
  ]},
  {title:'✉️ Writing · Cover Letters',subtitle:'Errores frecuentes y registro profesional',sections:[
    {label:'bad',labelText:'Errores de verbo muy frecuentes',text:'',examples:[{type:'bad',text:'❌ I always shown interest\n❌ I have a Masters degree\n❌ I can fast learner'},{type:'good',text:"✅ I have always shown interest\n✅ I have a Master's degree\n✅ I am a fast learner"}]},
    {label:'bad',labelText:'False friends en cover letters',text:'',examples:[{type:'bad',text:"❌ emphatic → ✅ empathetic\n❌ compromise (noun) → ✅ commitment\n❌ formation → ✅ training\n❌ actual job → ✅ current job\n❌ Due to my compromise… → ✅ Due to my commitment…"}]},
    {label:'bad',labelText:'Vocabulario laboral incorrecto',text:'',examples:[{type:'bad',text:'❌ volunteering position for the accommodation of immigrants\n❌ public attention jobs'},{type:'good',text:'✅ a volunteer position supporting immigrant integration\n✅ customer-facing roles'}]},
    {label:'tip',labelText:'Patrones españoles a evitar',text:'',examples:[{type:'bad',text:'❌ I am writing to you in concern of…\n❌ Help them integrate our society is the big challenge'},{type:'good',text:'✅ I am writing regarding…\n✅ Helping them integrate into society is a major challenge.'}]},
  ]},
  {title:'🧩 Mediation · Errores clave',subtitle:'Los errores más penalizados en mediación C1',sections:[
    {label:'bad',labelText:'Subject-verb agreement',text:'Errores de nivel B2, muy penalizados en C1.',examples:[{type:'bad',text:"❌ She need a student visa\n❌ Megan don't need a visa\n❌ The documents is required"},{type:'good',text:"✅ She needs a student visa\n✅ Megan doesn't need a visa\n✅ The documents are required"}]},
    {label:'bad',labelText:'False friends en mediación',text:'',examples:[{type:'bad',text:'❌ educative system → ✅ education system\n❌ penal antecedents → ✅ criminal record\n❌ actual level → ✅ current level\n❌ formation → ✅ education / training'}]},
    {label:'bad',labelText:'Patrones españoles copiados',text:'',examples:[{type:'bad',text:'❌ It is recommended to consult the embassy\n❌ Regarding to the requirements…\n❌ It is many schools in Madrid'},{type:'good',text:'✅ It is recommended that you consult the embassy\n✅ Regarding the requirements…\n✅ Madrid has many schools that receive foreign students'}]},
    {label:'bad',labelText:'Vocabulario incorrecto',text:'',examples:[{type:'bad',text:'❌ study permission → ✅ student visa\n❌ private health assistance → ✅ private health insurance\n❌ superior studies → ✅ higher education\n❌ gain a scholarship → ✅ apply for a scholarship\n❌ pass the documentation → ✅ submit the documentation'}]},
    {label:'tip',labelText:'Interpretación y hedging',text:'Uno de los errores más graves es malinterpretar el texto original. No hagas afirmaciones absolutas.',examples:[{type:'bad',text:"❌ She doesn't need any visa because she is under 18."},{type:'good',text:'✅ According to the article, minors may attend compulsory education without a visa; however, for Bachillerato, students need to regularise their legal situation.'}]},
  ]},
  {title:'📖 Reading & Listening · Estrategias C1',subtitle:'Cómo evitar los distractores más comunes',sections:[
    {label:'tip',labelText:'Idea clave',text:'En C1, más de una opción puede ser verdadera según el texto, pero solo una responde a la pregunta. Tu trabajo es elegir lo que es RELEVANTE, no solo lo que es verdadero.',examples:[]},
    {label:'bad',labelText:'Distractores más comunes',text:'',examples:[{type:'bad',text:'❌ Verdadero pero irrelevante: aparece en el texto pero no responde la pregunta.\n❌ Word-spotting: mismo vocabulario, significado diferente.\n❌ Overgeneralización: "always", "never", "everyone".\n❌ Common sense: parece lógico pero no se puede probar desde el texto.'},{type:'tip',text:'✅ Fíjate en: modificadores (mainly, partly, tends to), contraste (however, although, yet), tono (critical, cautious, enthusiastic).'}]},
    {label:'tip',labelText:'Matching — el error clásico',text:'Mismo tema ≠ mismo significado.',examples:[{type:'bad',text:'❌ Matching porque hay una palabra en común\n❌ Mismo tema, foco diferente\n❌ No distinguir entre experiencia personal y opinión general'},{type:'tip',text:'✅ Fíjate en: verbos y acciones, causa → efecto, actitud (positiva, crítica, resignada)'}]},
    {label:'tip',labelText:'Checklist final',text:'',examples:[{type:'tip',text:'• ¿Esta opción realmente responde a la pregunta?\n• ¿Es verdadera pero irrelevante?\n• ¿Puedo probarlo desde el texto o el audio?\n• ¿Estoy comparando significados, no palabras?'}]},
  ]},
  {title:'⚙️ Grammar · Passive structures',subtitle:'Estructuras pasivas formales para planes y predicciones C1',sections:[
    {label:'tip',labelText:'Estructuras clave',text:'',examples:[{type:'good',text:'✅ The new metro line is projected to be completed by 2027.\n✅ The park is intended to be a green space for all residents.\n✅ The population is set to rise significantly over the next decade.\n✅ By 2030, the city is expected to have reached carbon neutrality.'}]},
    {label:'tip',labelText:'Hedging con pasivas',text:'',examples:[{type:'good',text:"✅ It is widely believed that greener areas should be developed.\n✅ The quality of life is likely to be greatly improved.\n✅ It is reported that pollution levels are the highest in a decade."}]},
  ]},
  {title:'🔗 Grammar · Ellipsis & Substitution',subtitle:'Cómo evitar repeticiones de forma natural',sections:[
    {label:'tip',labelText:'Sustitución con "do"',text:'',examples:[{type:'good',text:"✅ 'Has anyone booked a room?' 'Yeah, I did.'\n✅ 'Does Ricardo speak German?' 'No, but I think Erica does.'"}]},
    {label:'tip',labelText:'Elipsis tras auxiliar o modal',text:'',examples:[{type:'good',text:"✅ 'Are they coming?' 'Yes, they are.'\n✅ I don't think anyone else is going, but I might.\n✅ 'You should have come.' 'I was going to, but something came up.'"}]},
    {label:'tip',labelText:'Elipsis tras "to"',text:'',examples:[{type:'good',text:"✅ 'Would you like to join us?' 'Yes, I'd love to.'\n✅ Some people give up sugar, but I didn't want to."}]},
    {label:'tip',labelText:'"do so" — uso formal',text:'',examples:[{type:'good',text:"✅ The minister refused to resign, saying he had no intention to do so.\n✅ Once we have done so, we will send you your account details."}]},
  ]},
];

function buildTheory(){
  const container=document.getElementById('theory-content');
  container.innerHTML=THEORY_DATA.map((section,si)=>`
    <div class="theory-section">
      <button class="theory-header" onclick="toggleTheory(${si})" id="th-${si}">
        <div><div class="theory-title">${section.title}</div><div class="theory-subtitle">${section.subtitle}</div></div>
        <span class="theory-arrow">▼</span>
      </button>
      <div class="theory-body" id="tb-${si}">
        ${section.sections.map(s=>`
          <div class="theory-rule">
            <div class="rule-label ${s.label}">${s.labelText}</div>
            ${s.text?`<div class="rule-text">${s.text}</div>`:''}
            ${s.examples.map(ex=>`<div class="rule-example ${ex.type==='bad'?'bad-ex':ex.type==='good'?'good-ex':'tip-ex'}">${ex.text}</div>`).join('')}
          </div>`).join('')}
      </div>
    </div>`).join('');
}
function toggleTheory(idx){
  document.getElementById('th-'+idx).classList.toggle('open');
  document.getElementById('tb-'+idx).classList.toggle('open');
}


/* ── COLLOCATIONS ── */
let collocations=[],collDeck=[],collIdx=0,collScore=0,collMode='complete',collTopic='all',collAnswered=false;

function loadCollocations(data){
  collocations=data.collocations||(Array.isArray(data)?data:[]);
  buildCollTopics();
  document.getElementById('coll-total').textContent=collocations.length;
  restartCollocations();
}

function buildCollTopics(){
  const topics=['all',...new Set(collocations.map(c=>c.topic).filter(Boolean))];
  document.getElementById('coll-topic-bar').innerHTML=topics.map(t=>
    `<button class="topic-btn${t===collTopic?' active':''}" onclick="setCollTopic('${t}')">${t==='all'?'Todos':t.replace('Collocations · ','')}</button>`
  ).join('');
}

function setCollTopic(t){collTopic=t;buildCollTopics();restartCollocations();}
function setCollMode(m){
  collMode=m;
  document.querySelectorAll('[data-cmode]').forEach(b=>b.classList.toggle('active',b.dataset.cmode===m));
  restartCollocations();
}

function restartCollocations(){
  const base=collTopic==='all'?collocations:collocations.filter(c=>c.topic===collTopic);
  collDeck=shuffle([...base]);
  collIdx=0;collScore=0;collAnswered=false;
  document.getElementById('coll-score').textContent='0';
  document.getElementById('coll-total').textContent=collDeck.length;
  renderCollocation();
}

function renderCollocation(){
  const area=document.getElementById('coll-area');
  if(!collDeck.length){
    area.innerHTML=`<div class="empty-state"><div class="big">🔗</div>No hay collocations para este filtro.</div>`;
    return;
  }
  if(collIdx>=collDeck.length){
    const pct=Math.round((collScore/collDeck.length)*100);
    area.innerHTML=`<div class="round-done"><div class="big">${pct>=70?'🎉':'💪'}</div><h2>¡Completado!</h2><p>Acertaste <b>${collScore} de ${collDeck.length}</b> (${pct}%)</p><button class="repeat-btn" onclick="restartCollocations()">↺ Repetir</button></div>`;
    return;
  }
  collAnswered=false;
  const c=collDeck[collIdx];
  const pct=Math.round((collIdx/collDeck.length)*100);
  const progHtml=`<div class="prog-row" style="margin-bottom:12px"><div class="prog-bar"><div class="prog-fill" style="width:${pct}%"></div></div><span class="prog-label">${collIdx+1}/${collDeck.length}</span></div>`;

  if(collMode==='natural'){
    renderCollNatural(c,progHtml,area);
  } else if(collMode==='mc'){
    renderCollMC(c,progHtml,area);
  } else {
    renderCollComplete(c,progHtml,area);
  }
}

function renderCollComplete(c,progHtml,area){
  const base=c.verb||c.adjective||c.pattern||'?';
  const target=c.collocate||c.noun||c.object||c.pattern||'';
  const tE=encodeURIComponent(target),wE=encodeURIComponent(c.word),eE=encodeURIComponent(c.error||'[ninguno]'),xE=encodeURIComponent(c.example||'');
  area.innerHTML=`${progHtml}
    <div class="coll-card">
      <div class="quiz-meta"><span>${(c.topic||''). replace('Collocations · ','')}</span></div>
      <div class="coll-base">${base} + ___</div>
      <div class="coll-hint" style="margin-bottom:6px">${c.translation}</div>
      <div style="font-size:12px;color:var(--text3);margin-bottom:14px">Escribe el collocate o la frase completa</div>
      <div class="type-in-wrap">
        <input class="type-in-input" id="coll-input" type="text" placeholder="Escribe tu respuesta" autocomplete="off" autocorrect="off" spellcheck="false" onkeydown="if(event.key==='Enter')checkCollComplete('${tE}','${wE}','${eE}','${xE}')">
        <button class="check-btn" onclick="checkCollComplete('${tE}','${wE}','${eE}','${xE}')">Comprobar</button>
      </div>
      <div id="coll-feedback"></div>
    </div>
    <button class="quiz-next-btn" id="coll-next" onclick="collNext()">Siguiente →</button>`;
  setTimeout(()=>{const i=document.getElementById('coll-input');if(i)i.focus();},300);
}

function checkCollComplete(target,word,error,example){
  if(collAnswered)return;
  const input=document.getElementById('coll-input');
  if(!input||!input.value.trim())return;
  collAnswered=true;
  const given=normalise(input.value.trim().toLowerCase());
  const tgt=decodeURIComponent(target);   // e.g. "a mistake"
  const fullWord=decodeURIComponent(word); // e.g. "make a mistake"
  // Build all valid answers: just the collocate OR the full collocation
  const collocateAlts=tgt.split('/').map(a=>normalise(a.trim().toLowerCase()));
  const fullAlts=fullWord.split('/').map(a=>normalise(a.trim().toLowerCase()));
  const allAlts=[...collocateAlts,...fullAlts];
  const correct=allAlts.some(a=>given===a);
  if(correct)collScore++;
  document.getElementById('coll-score').textContent=collScore;
  input.disabled=true;
  document.querySelectorAll('.check-btn').forEach(b=>b.disabled=true);
  input.classList.add(correct?'correct':'wrong');
  const fb=document.getElementById('coll-feedback');
  const errText=decodeURIComponent(error);
  const exText=decodeURIComponent(example);
  fb.innerHTML=`
    <div class="coll-correct" style="margin-top:12px">${correct?'✅ Correcto:':'❌ Respuesta:'} <b>${fullWord}</b></div>
    <div style="font-size:13px;color:var(--text3);margin-top:4px">(puedes escribir solo "<i>${tgt}</i>" o la frase completa)</div>
    ${!correct?`<div style="font-size:14px;padding:8px 12px;background:var(--bg2);border-radius:8px;margin-top:8px;color:var(--text2)">Escribiste: <i>${input.value.trim()}</i></div>`:''}
    ${errText?`<div class="coll-error-badge" style="margin-top:8px">${errText}</div>`:''}
    ${exText?`<div class="coll-example" style="margin-top:8px">"${exText}"</div>`:''}`;
  document.getElementById('coll-next').classList.add('visible');
}

function renderCollMC(c,progHtml,area){
  const target=c.collocate||c.noun||c.object||c.pattern||'';
  const base=c.verb||c.adjective||c.pattern||'?';
  // generate 3 distractors from other collocations
  const others=shuffle(collDeck.filter((_,i)=>i!==collIdx)).slice(0,3);
  const distractors=others.map(o=>o.collocate||o.noun||o.object||o.pattern||'other').filter(d=>d!==target);
  const opts=shuffle([target,...distractors.slice(0,3)]);
  area.innerHTML=`${progHtml}
    <div class="coll-card">
      <div class="quiz-meta"><span>${(c.topic||'').replace('Collocations · ','')}</span></div>
      <div class="coll-base">${base} + ___</div>
      <div class="coll-hint">${c.translation}</div>
      <div class="options-grid" id="coll-opts">
        ${opts.map((o,i)=>`<button class="option-btn" onclick="checkCollMC(${i},'${encodeURIComponent(target)}','${encodeURIComponent(c.word)}','${encodeURIComponent(c.error||'')}','${encodeURIComponent(c.example||'')}')" data-val="${encodeURIComponent(o)}">${o}</button>`).join('')}
      </div>
      <div id="coll-feedback"></div>
    </div>
    <button class="quiz-next-btn" id="coll-next" onclick="collNext()">Siguiente →</button>`;
}

function checkCollMC(idx,target,word,error,example){
  if(collAnswered)return;
  collAnswered=true;
  const btns=document.querySelectorAll('#coll-opts .option-btn');
  const chosen=decodeURIComponent(btns[idx].dataset.val);
  const expected=decodeURIComponent(target);
  const correct=chosen===expected;
  if(correct)collScore++;
  document.getElementById('coll-score').textContent=collScore;
  btns.forEach(b=>{b.disabled=true;const v=decodeURIComponent(b.dataset.val);if(v===expected)b.classList.add('correct');else if(b===btns[idx]&&!correct)b.classList.add('wrong');});
  const fb=document.getElementById('coll-feedback');
  const errText=decodeURIComponent(error);
  const exText=decodeURIComponent(example);
  fb.innerHTML=`<div class="coll-correct" style="margin-top:12px">✅ ${decodeURIComponent(word)}</div>
    ${errText?`<div class="coll-error-badge">${errText}</div>`:''}
    ${exText?`<div class="coll-example">"${exText}"</div>`:''}`;
  document.getElementById('coll-next').classList.add('visible');
}

function renderCollNatural(c,progHtml,area){
  // show correct collocation vs a wrong one using the error field
  const correct=c.word;
  // extract wrong form from error field e.g. "❌ strong rain → ✅ heavy rain" → "strong rain"
  let wrongForm=c.error||'';
  const m=wrongForm.match(/❌\s*([^→✅,]+)/);
  const wrongText=m?m[1].trim():`*${(c.verb||c.adjective||'')} + wrong`;
  const opts=shuffle([{text:correct,isCorrect:true},{text:wrongText,isCorrect:false}]);
  area.innerHTML=`${progHtml}
    <div class="coll-card">
      <div class="quiz-meta"><span>${(c.topic||'').replace('Collocations · ','')}</span></div>
      <div style="font-size:15px;color:var(--text2);margin-bottom:16px;text-align:center;line-height:1.6">¿Cuál suena más natural?<br><span style="font-size:13px;color:var(--text3)">${c.translation}</span></div>
      <div class="nat-pair" id="nat-opts">
        ${opts.map((o,i)=>`<button class="nat-btn" onclick="checkNatural(${i},${o.isCorrect},'${encodeURIComponent(correct)}','${encodeURIComponent(c.error||'')}','${encodeURIComponent(c.example||'')}')">${o.text}</button>`).join('')}
      </div>
      <div id="coll-feedback"></div>
    </div>
    <button class="quiz-next-btn" id="coll-next" onclick="collNext()">Siguiente →</button>`;
}

function checkNatural(idx,isCorrect,word,error,example){
  if(collAnswered)return;
  collAnswered=true;
  if(isCorrect)collScore++;
  document.getElementById('coll-score').textContent=collScore;
  const btns=document.querySelectorAll('#nat-opts .nat-btn');
  btns.forEach((b,i)=>{b.disabled=true;b.classList.add(i===idx?(isCorrect?'nat-correct':'nat-wrong'):(i!==idx?'nat-correct':''));});
  const fb=document.getElementById('coll-feedback');
  const errText=decodeURIComponent(error);
  const exText=decodeURIComponent(example);
  fb.innerHTML=`<div class="explanation-box${isCorrect?'':' wrong-ex'}" style="margin-top:10px">
    <div class="ex-label">${isCorrect?'✓ Correcto':'✗ Incorrecto'}</div>
    ✅ La forma natural es: <b>${decodeURIComponent(word)}</b><br>
    ${errText?`<span style="opacity:.85">${errText}</span><br>`:''}
    ${exText?`<span style="font-style:italic;opacity:.8">"${exText}"</span>`:''}
  </div>`;
  document.getElementById('coll-next').classList.add('visible');
}

function collNext(){
  if(!collAnswered) return;
  collIdx++;renderCollocation();
}

/* ── REWRITING ── */
const REWRITE_EXERCISES=[
  // Conditionals
  {id:'r1',category:'conditionals',original:"He didn't study, so he failed the exam.",keyword:"HAD",answer:"If he had studied, he wouldn't have failed the exam.",hint:"3rd conditional: If + past perfect → would have + past participle"},
  {id:'r2',category:'conditionals',original:"She doesn't exercise, so she feels tired.",keyword:"IF",answer:"If she exercised, she wouldn't feel so tired.",hint:"2nd conditional: If + past simple → would + base verb"},
  {id:'r3',category:'conditionals',original:"They didn't warn us, so we weren't prepared.",keyword:"HAD",answer:"Had they warned us, we would have been prepared.",hint:"Inverted 3rd conditional: Had + subject + past participle (sin 'if')"},
  {id:'r4',category:'conditionals',original:"Without proper funding, the project will fail.",keyword:"UNLESS",answer:"Unless the project receives proper funding, it will fail.",hint:"unless = if not. Usa presente simple en la cláusula con unless."},
  {id:'r5',category:'conditionals',original:"You should apply now. Otherwise you'll miss the deadline.",keyword:"PROVIDED",answer:"Provided that you apply now, you won't miss the deadline.",hint:"provided (that) = as long as, on condition that"},
  {id:'r6',category:'conditionals',original:"I didn't know about the change, so I couldn't prepare.",keyword:"KNOWN",answer:"Had I known about the change, I could have prepared.",hint:"Inverted 3rd conditional: Had I known... (formal, sin 'if')"},
  {id:'r7',category:'conditionals',original:"He is very experienced, so he manages difficult situations well.",keyword:"WERE",answer:"Were he less experienced, he would struggle with difficult situations.",hint:"Inverted 2nd conditional: Were + subject + adjective (sin 'if')"},
  // Passive
  {id:'r8',category:'passive',original:"The government will announce the new policy next week.",keyword:"ANNOUNCED",answer:"The new policy will be announced by the government next week.",hint:"Future passive: will be + past participle"},
  {id:'r9',category:'passive',original:"They expect the project to finish by December.",keyword:"EXPECTED",answer:"The project is expected to be finished by December.",hint:"Passive reporting verb: is expected to be + past participle"},
  {id:'r10',category:'passive',original:"People believe that exercise improves mental health.",keyword:"BELIEVED",answer:"It is believed that exercise improves mental health.",hint:"Passive reporting: It is believed that... (impersonal passive)"},
  {id:'r11',category:'passive',original:"Someone needs to address this issue urgently.",keyword:"ADDRESSED",answer:"This issue needs to be addressed urgently.",hint:"need + to be + past participle (pasivo con need)"},
  {id:'r12',category:'passive',original:"The council is considering demolishing the old building.",keyword:"DEMOLISHED",answer:"The old building is being considered for demolition / is being considered to be demolished.",hint:"Passive continuous: is being + past participle"},
  {id:'r13',category:'passive',original:"They reported that several people were injured.",keyword:"REPORTED",answer:"It was reported that several people had been injured.",hint:"Reported passive: It was reported that... (backshift del tiempo verbal)"},
  // Modals
  {id:'r14',category:'modals',original:"It wasn't necessary for her to attend the meeting.",keyword:"NEED",answer:"She needn't have attended the meeting.",hint:"needn't have + past participle = no era necesario pero lo hizo"},
  {id:'r15',category:'modals',original:"I'm sure he didn't mean to offend anyone.",keyword:"HAVE",answer:"He can't have meant to offend anyone.",hint:"can't have + past participle = certeza de que algo NO ocurrió"},
  {id:'r16',category:'modals',original:"Perhaps she forgot to send the email.",keyword:"MIGHT",answer:"She might have forgotten to send the email.",hint:"might have + past participle = posibilidad en el pasado"},
  {id:'r17',category:'modals',original:"It was a mistake to accept the offer.",keyword:"SHOULD",answer:"He shouldn't have accepted the offer.",hint:"shouldn't have + past participle = crítica de algo ya hecho"},
  {id:'r18',category:'modals',original:"I'm certain that they received the message.",keyword:"MUST",answer:"They must have received the message.",hint:"must have + past participle = certeza lógica sobre el pasado"},
  {id:'r19',category:'modals',original:"It's possible that the flight was delayed.",keyword:"COULD",answer:"The flight could have been delayed.",hint:"could have + past participle = posibilidad en el pasado"},
  // Mixed C1
  {id:'r20',category:'mixed',original:"Despite the rain, they finished the match.",keyword:"DESPITE",answer:"Despite the rain, they managed to finish the match.",hint:"despite + noun/-ing (no se usa despite + that o despite + clause)"},
  {id:'r21',category:'mixed',original:"He is too young to understand the situation.",keyword:"ENOUGH",answer:"He is not old enough to understand the situation.",hint:"not + adj + enough + to + infinitive (opuesto de 'too + adj')"},
  {id:'r22',category:'mixed',original:"The last time I saw her was three years ago.",keyword:"SINCE",answer:"I haven't seen her since three years ago / for three years.",hint:"present perfect + since/for para hablar del tiempo transcurrido"},
  {id:'r23',category:'mixed',original:"It's a pity she didn't come to the event.",keyword:"WISH",answer:"I wish she had come to the event.",hint:"wish + past perfect = lamentarse de algo que no ocurrió en el pasado"},
  {id:'r24',category:'mixed',original:"She was so tired that she fell asleep immediately.",keyword:"SUCH",answer:"She was such a tired person that she fell asleep immediately. / It was such a tiring day that she fell asleep immediately.",hint:"such + a/an + adj + noun + that (contraste con 'so + adj + that')"},
  {id:'r25',category:'mixed',original:"I regret not applying for that job.",keyword:"WISH",answer:"I wish I had applied for that job.",hint:"wish + past perfect para lamentarse de algo no hecho"},
  {id:'r26',category:'mixed',original:"The company spent a lot on advertising but didn't increase sales.",keyword:"DESPITE",answer:"Despite spending a lot on advertising, the company didn't increase sales.",hint:"despite + -ing (gerundio, no infinitivo ni 'that')"},
  {id:'r27',category:'mixed',original:"No other city in the region is as innovative as Barcelona.",keyword:"MOST",answer:"Barcelona is the most innovative city in the region.",hint:"superlativo: the most + adjective + in/of"},
];

let rwDeck=[],rwIdx=0,rwScore=0,rwFilter='all',rwAnswered=false;

function restartRewriting(){
  const base=rwFilter==='all'?REWRITE_EXERCISES:REWRITE_EXERCISES.filter(e=>e.category===rwFilter);
  rwDeck=shuffle([...base]);
  rwIdx=0;rwScore=0;rwAnswered=false;
  document.getElementById('rw-score').textContent='0';
  document.getElementById('rw-total').textContent=rwDeck.length;
  renderRewrite();
}

function setRwFilter(f){
  rwFilter=f;
  document.querySelectorAll('[data-rwfilter]').forEach(b=>b.classList.toggle('active',b.dataset.rwfilter===f));
  restartRewriting();
}

function renderRewrite(){
  const area=document.getElementById('rw-area');
  document.getElementById('rw-score').textContent=rwScore;
  if(!rwDeck.length){area.innerHTML=`<div class="empty-state"><div class="big">✍️</div>No hay ejercicios para este filtro.</div>`;return;}
  if(rwIdx>=rwDeck.length){
    const pct=Math.round((rwScore/rwDeck.length)*100);
    area.innerHTML=`<div class="round-done"><div class="big">${pct>=70?'🎉':'💪'}</div><h2>¡Completado!</h2><p>Acertaste <b>${rwScore} de ${rwDeck.length}</b> (${pct}%)</p><button class="repeat-btn" onclick="restartRewriting()">↺ Repetir</button></div>`;
    return;
  }
  rwAnswered=false;
  const ex=rwDeck[rwIdx];
  const pct=Math.round((rwIdx/rwDeck.length)*100);
  const catLabel={conditionals:'Condicionales',passive:'Voz Pasiva',modals:'Modales',mixed:'C1 Mixed'}[ex.category]||ex.category;
  area.innerHTML=`
    <div class="prog-row" style="margin-bottom:12px">
      <div class="prog-bar"><div class="prog-fill" style="width:${pct}%"></div></div>
      <span class="prog-label">${rwIdx+1}/${rwDeck.length}</span>
    </div>
    <div class="rw-card">
      <div class="quiz-meta"><span>${catLabel}</span><span>Rewrite</span></div>
      <div style="font-size:13px;color:var(--text3);margin-bottom:8px;font-weight:600">Frase original:</div>
      <div class="rw-original">${ex.original}</div>
      <div class="rw-keyword">Palabra clave: ${ex.keyword}</div>
      <div style="font-size:13px;color:var(--text2);margin-bottom:10px">Reescribe usando la palabra clave. No cambies el significado.</div>
      <textarea class="rw-input" id="rw-input" rows="2" placeholder="Escribe aquí tu versión..." onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();checkRewrite();}">${ex.keyword} </textarea>
      <button class="rw-check-btn" onclick="checkRewrite()">Comprobar con IA</button>
      <div id="rw-feedback"></div>
    </div>
    <button class="quiz-next-btn" id="rw-next" onclick="rwNext()">Siguiente →</button>`;
  setTimeout(()=>{const i=document.getElementById('rw-input');if(i){i.focus();const l=i.value.length;i.setSelectionRange(l,l);}},300);
}

function checkRewrite(){
  if(rwAnswered)return;
  const input=document.getElementById('rw-input');
  const btn=document.querySelector('.rw-check-btn');
  if(!input||!input.value.trim())return;
  const val=input.value.trim();
  if(normalise(val.toLowerCase())===normalise(rwDeck[rwIdx].keyword.toLowerCase()))return;
  rwAnswered=true;
  btn.disabled=true;
  input.disabled=true;
  const ex=rwDeck[rwIdx];
  const fb=document.getElementById('rw-feedback');
  // Smart check: compare key structural words, case-insensitive
  const given=normalise(val.toLowerCase());
  // Accept if all key words from expected answer appear in given answer
  const expected=normalise(ex.answer.toLowerCase());
  const keyWords=expected.split(/\s+/).filter(w=>w.length>3&&!['that','with','have','been','were','would','could','should','will','from','into','this','they','them','their','what','when','where','which','there'].includes(w));
  const matchCount=keyWords.filter(w=>given.includes(w)).length;
  const correct=matchCount>=Math.ceil(keyWords.length*0.75)&&given.length>10;
  if(correct)rwScore++;
  document.getElementById('rw-score').textContent=rwScore;
  input.style.borderColor=correct?'var(--green)':'var(--red)';
  fb.innerHTML=`
    <div class="rw-answer-reveal">✅ Respuesta modelo: <b>${ex.answer}</b></div>
    <div class="rw-ai-feedback${correct?'':' wrong-ex'}" style="margin-top:10px">
      <div class="ex-label">${correct?'✓ Bien orientado':'✗ Revisa'}</div>
      ${correct
        ?'Tu respuesta recoge los elementos clave. ¡Bien!'
        :`Tu respuesta: <i>"${val}"</i><br><br>Compara con el modelo y fíjate en: <b>${ex.keyword}</b>`}
    </div>
    <div style="font-size:13px;color:var(--text3);margin-top:8px;padding:8px 12px;background:var(--bg2);border-radius:8px;line-height:1.6">💡 ${ex.hint}</div>`;
  document.getElementById('rw-next').classList.add('visible');
}

function rwNext(){rwIdx++;renderRewrite();}

/* ═══════════════════════════════════════════
   SPACED REPETITION
═══════════════════════════════════════════ */
const SR_KEY='sr_progress_v1';
// intervals in ms: new→1d, hard→3d, known→7d, mastered→14d
const SR_INTERVALS={no:0,hard:3*86400000,known:7*86400000,mastered:14*86400000};
let srData={};// {word:{status,nextReview,reviewCount}}

function loadSR(){try{srData=JSON.parse(localStorage.getItem(SR_KEY)||'{}');}catch(e){srData={};}}
function saveSR(){try{localStorage.setItem(SR_KEY,JSON.stringify(srData));}catch(e){}}

function srRate(word,val){
  const now=Date.now();
  const cur=srData[word]||{status:'new',nextReview:0,reviewCount:0};
  const count=(cur.reviewCount||0)+1;
  let next=now;
  if(val==='known'){
    // promote: if reviewed 2+ times as known, mark mastered
    const status=count>=3?'mastered':'known';
    next=now+(status==='mastered'?SR_INTERVALS.mastered:SR_INTERVALS.known);
    srData[word]={status,nextReview:next,reviewCount:count};
  } else if(val==='hard'){
    srData[word]={status:'hard',nextReview:now+SR_INTERVALS.hard,reviewCount:count};
  } else {
    srData[word]={status:'no',nextReview:now+86400000,reviewCount:0};// reset
  }
  saveSR();
}

function srDueWords(){
  const now=Date.now();
  return vocab.filter(v=>{
    const s=srData[v.word];
    if(!s)return true;// never reviewed
    if(s.status==='mastered')return now>=s.nextReview;
    return now>=s.nextReview;
  });
}

function renderSRBanner(){
  const due=srDueWords();
  const banner=document.getElementById('sr-banner');
  const text=document.getElementById('sr-banner-text');
  if(!banner)return;
  if(due.length>0){
    banner.style.display='flex';
    text.textContent=`Tienes ${due.length} palabra${due.length===1?'':'s'} pendiente${due.length===1?'':'s'} de repaso hoy`;
  } else {
    banner.style.display='none';
  }
}

/* ═══════════════════════════════════════════
   UPDATE DECK — add 'due' mode
═══════════════════════════════════════════ */
function updateDeck(){
  const base=filteredVocab();
  if(currentMode==='due'){
    const now=Date.now();
    currentDeck=shuffle(base.filter(v=>{const s=srData[v.word];return !s||now>=s.nextReview;}));
  } else if(currentMode==='hard'){
    currentDeck=shuffle(base.filter(v=>progress[v.word]==='hard'||progress[v.word]==='no'));
  } else if(currentMode==='review'){
    currentDeck=shuffle(base.filter(v=>progress[v.word]==='known'));
  } else {
    const no=shuffle(base.filter(v=>progress[v.word]==='no'));
    const hard=shuffle(base.filter(v=>progress[v.word]==='hard'));
    const unseen=shuffle(base.filter(v=>!progress[v.word]));
    const known=shuffle(base.filter(v=>progress[v.word]==='known'));
    currentDeck=[...no,...hard,...unseen,...known];
  }
  currentIdx=0;flipped=false;updateModeCounts();renderSRBanner();renderCard();
}

function updateModeCounts(){
  const base=filteredVocab();
  const now=Date.now();
  const due=base.filter(v=>{const s=srData[v.word];return !s||now>=s.nextReview;});
  document.getElementById('mc-all').textContent='\n'+base.length;
  document.getElementById('mc-due').textContent='\n'+due.length+(due.length>0?'🔴':'');
  document.getElementById('mc-hard').textContent='\n'+base.filter(v=>progress[v.word]==='hard'||progress[v.word]==='no').length;
  document.getElementById('mc-review').textContent='\n'+base.filter(v=>progress[v.word]==='known').length;
}

/* ═══════════════════════════════════════════
   ERROR DETECTION
═══════════════════════════════════════════ */
const DETECT_EXERCISES=[
  {id:'d1',sentence:"He did a decision without consulting the team.",error:"did a decision",correct:"made a decision",explanation:"'make a decision' es la collocation correcta. 'Do' no colocaciona con 'decision'."},
  {id:'d2',sentence:"She has a very strong knowledge of grammar.",error:"strong knowledge",correct:"good / thorough knowledge",explanation:"'Knowledge' colocaciona con 'good', 'thorough' o 'extensive', no con 'strong'."},
  {id:'d3',sentence:"The government needs to do an effort to reduce pollution.",error:"do an effort",correct:"make an effort",explanation:"'Make an effort' es la collocation natural. 'Do' no se usa con 'effort'."},
  {id:'d4',sentence:"We should rise awareness about climate change.",error:"rise awareness",correct:"raise awareness",explanation:"'Raise awareness' (no 'rise'). Rise es intransitivo; raise es transitivo y significa 'elevar'."},
  {id:'d5',sentence:"He made a party to celebrate his promotion.",error:"made a party",correct:"had / threw a party",explanation:"'Have a party' o 'throw a party' son las collocations naturales. 'Make a party' es un calco del español."},
  {id:'d6',sentence:"Despite of the rain, they finished the match.",error:"Despite of",correct:"Despite",explanation:"'Despite' nunca va seguido de 'of'. Es directamente 'despite + noun/-ing'. 'In spite of' sí lleva 'of'."},
  {id:'d7',sentence:"She is very emphatic with her students.",error:"emphatic",correct:"empathetic",explanation:"'Emphatic' significa 'enfático/contundente'. 'Empathetic' significa 'empático'. Falso amigo del español."},
  {id:'d8',sentence:"The documents is required by the administration.",error:"is required",correct:"are required",explanation:"'Documents' es plural → 'are required'. Error de concordancia sujeto-verbo."},
  {id:'d9',sentence:"She will need to request for a student visa.",error:"request for",correct:"apply for",explanation:"'Apply for a visa' es la collocation correcta. 'Request for' no es natural en este contexto."},
  {id:'d10',sentence:"They did a great progress on the project last week.",error:"did a great progress",correct:"made great progress",explanation:"'Make progress' (no 'do') y 'progress' es incontable (no lleva artículo: ❌ a progress)."},
  {id:'d11',sentence:"Due to my compromise with the project, I worked overtime.",error:"compromise",correct:"commitment",explanation:"'Compromise' en inglés significa 'acuerdo de concesiones mutuas'. 'Commitment' = compromiso/dedicación."},
  {id:'d12',sentence:"I am writing to you in concern of the recent changes.",error:"in concern of",correct:"regarding / concerning",explanation:"'In concern of' es un calco del español. En inglés se dice 'regarding' o 'concerning'."},
  {id:'d13',sentence:"The new policy will have strong consequences on employment.",error:"strong consequences",correct:"serious / significant consequences",explanation:"'Consequences' colocaciona con 'serious', 'significant' o 'major', no con 'strong'."},
  {id:'d14',sentence:"He is a very actual expert in the field.",error:"actual",correct:"current / leading",explanation:"'Actual' en inglés significa 'real/verdadero', no 'actual/actual'. Falso amigo del español."},
  {id:'d15',sentence:"She passed the documentation to the committee.",error:"passed the documentation",correct:"submitted the documentation",explanation:"'Submit documentation' es el término formal correcto. 'Pass' es informal y no preciso en contextos académicos."},
  {id:'d16',sentence:"We need to make a deep research on this topic.",error:"make a deep research",correct:"carry out thorough research",explanation:"'Research' es incontable (sin artículo). 'Carry out research' o 'conduct research', no 'make research'."},
  {id:'d17',sentence:"The plan didn't materialize because of a lack of funds.",error:null,correct:null,explanation:"Esta frase es correcta. 'Materialize' = hacerse realidad, y la estructura es perfecta."},
  {id:'d18',sentence:"If he would have studied harder, he would have passed.",error:"would have studied",correct:"had studied",explanation:"En la cláusula 'if' de 3rd conditional: 'If + past perfect' (not 'would have'). ❌ If he would have → ✅ If he had."},
  {id:'d19',sentence:"She is used to work late every night.",error:"is used to work",correct:"is used to working",explanation:"'Be used to' va seguido de -ing (gerundio). ❌ is used to work → ✅ is used to working."},
  {id:'d20',sentence:"The council undertook a major renovation of the city centre.",error:null,correct:null,explanation:"Esta frase es correcta. 'Undertake' = emprender, y 'undertook' es su pasado irregular correcto."},
  {id:'d21',sentence:"She has been working here since five years.",error:"since five years",correct:"for five years",explanation:"'Since' se usa con punto en el tiempo (since 2010). 'For' con duración (for 5 years)."},
  {id:'d22',sentence:"I am not used to drive on the left.",error:"used to drive",correct:"used to driving",explanation:"'Be used to' va seguido de -ing (gerundio). ❌ used to drive → ✅ used to driving."},
  {id:'d23',sentence:"He suggested me to go to the doctor.",error:"suggested me to go",correct:"suggested that I go / suggested I go",explanation:"'Suggest' + objeto + to-infinitive es incorrecto. Usa 'suggest + that + subject + bare infinitive' o 'suggest + -ing'."},
  {id:'d24',sentence:"The book is based in a true story.",error:"based in",correct:"based on",explanation:"'Based on' = basado en. 'Based in' = ubicado en (para lugares)."},
  {id:'d25',sentence:"She is interested on art.",error:"interested on",correct:"interested in",explanation:"'Interested in' = interesado en. 'On' no es correcto aquí."},
  {id:'d26',sentence:"I am agree with you.",error:"am agree",correct:"agree",explanation:"'Agree' no necesita auxiliar 'be'. Es 'I agree with you'."},
  {id:'d27',sentence:"He works like a teacher.",error:"like a teacher",correct:"as a teacher",explanation:"'As' para profesiones/roles. 'Like' para similitudes físicas."},
  {id:'d28',sentence:"She can to swim very well.",error:"can to swim",correct:"can swim",explanation:"Después de 'can' va bare infinitive (sin 'to')."},
  {id:'d29',sentence:"They discussed about the problem.",error:"discussed about",correct:"discussed",explanation:"'Discuss' no necesita 'about'. Simplemente 'discuss + the problem'."},
  {id:'d30',sentence:"The meeting is in Monday.",error:"in Monday",correct:"on Monday",explanation:"Días de la semana usan 'on'. Meses usan 'in'."}
];

let detDeck=[],detIdx=0,detScore=0,detMode='tap',detAnswered=false;

function restartDetect(){
  detDeck=shuffle([...DETECT_EXERCISES]);
  detIdx=0;detScore=0;detAnswered=false;
  document.getElementById('det-score').textContent='0';
  document.getElementById('det-total').textContent=detDeck.length;
  renderDetect();
}
function setDetMode(m){
  detMode=m;
  document.querySelectorAll('[data-detmode]').forEach(b=>b.classList.toggle('active',b.dataset.detmode===m));
  restartDetect();
}

function renderDetect(){
  const area=document.getElementById('det-area');
  if(detIdx>=detDeck.length){
    const pct=Math.round((detScore/detDeck.length)*100);
    area.innerHTML=`<div class="round-done"><div class="big">${pct>=70?'🎉':'💪'}</div><h2>¡Completado!</h2><p>Acertaste <b>${detScore} de ${detDeck.length}</b> (${pct}%)</p><button class="repeat-btn" onclick="restartDetect()">↺ Repetir</button></div>`;
    return;
  }
  detAnswered=false;
  const ex=detDeck[detIdx];
  const pct=Math.round((detIdx/detDeck.length)*100);
  const progHtml=`<div class="prog-row" style="margin-bottom:12px"><div class="prog-bar"><div class="prog-fill" style="width:${pct}%"></div></div><span class="prog-label">${detIdx+1}/${detDeck.length}</span></div>`;

  if(detMode==='tap') renderDetectTap(ex,progHtml,area);
  else if(detMode==='mc') renderDetectMC(ex,progHtml,area);
  else renderDetectCorrect(ex,progHtml,area);
}

function renderDetectTap(ex,progHtml,area){
  const hasError=!!ex.error;
  // Build sentence with clickable words
  const words=ex.sentence.split(' ');
  const errorWords=ex.error?ex.error.toLowerCase().split(' '):[];
  const html=words.map((w,i)=>{
    const clean=w.replace(/[.,!?;:]/g,'').toLowerCase();
    const isErr=errorWords.includes(clean);
    return `<span class="${isErr?'err-word':''}" id="dw-${i}" ${isErr?`onclick="tapWord(${i},true)"`:''} style="cursor:${isErr?'pointer':'default'}">${w} </span>`;
  }).join('');
  area.innerHTML=`${progHtml}
    <div class="coll-card">
      <div class="quiz-meta"><span>Toca el error</span><span>${hasError?'Hay 1 error':'Puede ser correcta'}</span></div>
      <div style="font-size:13px;color:var(--text3);margin-bottom:12px;text-align:center">Toca la parte incorrecta, o indica si la frase es correcta</div>
      <div class="detect-sentence" id="det-sentence">${html}</div>
      ${hasError
        ?`<button class="detect-give-up" onclick="detGiveUp()">No encuentro el error → ver respuesta</button>`
        :`<button class="check-btn" style="margin-top:8px" onclick="detMarkCorrect()">✓ La frase es correcta</button>`
      }
      <div id="det-feedback"></div>
    </div>
    <button class="quiz-next-btn" id="det-next" onclick="detNext()">Siguiente →</button>`;
}

function tapWord(idx,isErr){
  if(detAnswered) return;
  detAnswered=true;
  const el=document.getElementById('dw-'+idx);
  if(isErr){
    detScore++;
    if(el) el.classList.add('found');
    document.getElementById('det-score').textContent=detScore;
    showDetFeedback(true);
  } else {
    if(el) el.classList.add('missed');
    showDetFeedback(false);
  }
}
function detGiveUp(){
  if(detAnswered)return;
  detAnswered=true;showDetFeedback(false);
}
function detMarkCorrect(){
  if(detAnswered)return;
  detAnswered=true;
  const ex=detDeck[detIdx];
  const correct=!ex.error;
  if(correct)detScore++;
  document.getElementById('det-score').textContent=detScore;
  showDetFeedback(correct);
}
function showDetFeedback(correct){
  const ex=detDeck[detIdx];
  const fb=document.getElementById('det-feedback');
  const nb=document.getElementById('det-next');
  if(nb)nb.classList.add('visible');
  if(!ex.error){
    fb.innerHTML=`<div class="explanation-box${correct?'':' wrong-ex'}" style="margin-top:12px">
      <div class="ex-label">${correct?'✓ Correcto — la frase no tiene error':'✗ Incorrecto — la frase es correcta'}</div>
      ${ex.explanation}</div>`;
  } else {
    fb.innerHTML=`<div class="explanation-box${correct?'':' wrong-ex'}" style="margin-top:12px">
      <div class="ex-label">${correct?'✓ ¡Encontraste el error!':'✗ El error estaba en: "'+ex.error+'"'}</div>
      ❌ <b>${ex.error}</b> → ✅ <b>${ex.correct}</b><br><br>${ex.explanation}</div>`;
  }
}

function renderDetectMC(ex,progHtml,area){
  const hasError=!!ex.error;
  // Options: A) the sentence is correct B) error + correction option
  let opts;
  if(hasError){
    opts=shuffle([
      {text:`"${ex.error}" → debería ser "${ex.correct}"`,isCorrect:true},
      {text:'La frase es correcta tal como está',isCorrect:false},
      {text:`"${ex.correct}" → debería ser "${ex.error}"`,isCorrect:false},
    ]);
  } else {
    opts=shuffle([
      {text:'La frase es correcta tal como está',isCorrect:true},
      {text:'Hay un error de concordancia verbal',isCorrect:false},
      {text:'Hay un false friend mal usado',isCorrect:false},
    ]);
  }
  area.innerHTML=`${progHtml}
    <div class="coll-card">
      <div class="quiz-meta"><span>Detecta el error</span></div>
      <div class="detect-sentence">${ex.sentence}</div>
      <div class="options-grid" id="det-opts">
        ${opts.map((o,i)=>`<button class="option-btn" onclick="checkDetMC(${i},${o.isCorrect},'${encodeURIComponent(ex.explanation)}')" >${o.text}</button>`).join('')}
      </div>
      <div id="det-feedback"></div>
    </div>
    <button class="quiz-next-btn" id="det-next" onclick="detNext()">Siguiente →</button>`;
}

function checkDetMC(idx,isCorrect,explanation){
  if(detAnswered)return;
  detAnswered=true;
  if(isCorrect)detScore++;
  document.getElementById('det-score').textContent=detScore;
  const btns=document.querySelectorAll('#det-opts .option-btn');
  btns.forEach((b,i)=>{b.disabled=true;if(i===idx)b.classList.add(isCorrect?'correct':'wrong');});
  const ex=detDeck[detIdx];
  document.getElementById('det-feedback').innerHTML=`<div class="explanation-box${isCorrect?'':' wrong-ex'}" style="margin-top:12px">
    <div class="ex-label">${isCorrect?'✓ Correcto':'✗ Incorrecto'}</div>
    ${ex.error?`❌ <b>${ex.error}</b> → ✅ <b>${ex.correct}</b><br><br>`:''}${decodeURIComponent(explanation)}</div>`;
  document.getElementById('det-next').classList.add('visible');
}

function renderDetectCorrect(ex,progHtml,area){
  area.innerHTML=`${progHtml}
    <div class="coll-card">
      <div class="quiz-meta"><span>Corrige la frase</span></div>
      <div class="detect-sentence">${ex.sentence}</div>
      ${ex.error
        ?`<div style="font-size:13px;color:var(--text2);margin-bottom:10px">Escribe la frase corregida (o solo la parte incorrecta):</div>
          <div class="type-in-wrap">
            <input class="type-in-input" id="det-input" type="text" placeholder="Escribe la corrección..." autocomplete="off" autocorrect="off" spellcheck="false" onkeydown="if(event.key==='Enter')checkDetCorrect()">
            <button class="check-btn" onclick="checkDetCorrect()">Comprobar</button>
          </div>`
        :`<button class="check-btn" style="margin-top:8px" onclick="detMarkCorrectFree()">✓ La frase es correcta</button>`
      }
      <div id="det-feedback"></div>
    </div>
    <button class="quiz-next-btn" id="det-next" onclick="detNext()">Siguiente →</button>`;
  if(ex.error)setTimeout(()=>{const i=document.getElementById('det-input');if(i)i.focus();},300);
}

function checkDetCorrect(){
  if(detAnswered)return;
  const input=document.getElementById('det-input');
  if(!input||!input.value.trim())return;
  detAnswered=true;
  const ex=detDeck[detIdx];
  const given=input.value.trim().toLowerCase();
  const correct=ex.correct?given.includes(ex.correct.toLowerCase().split('/')[0].trim()):false;
  if(correct)detScore++;
  document.getElementById('det-score').textContent=detScore;
  input.disabled=true;document.querySelector('.check-btn').disabled=true;
  input.classList.add(correct?'correct':'wrong');
  document.getElementById('det-feedback').innerHTML=`<div class="explanation-box${correct?'':' wrong-ex'}" style="margin-top:12px">
    <div class="ex-label">${correct?'✓ Correcto':'✗ Incorrecto'}</div>
    ❌ <b>${ex.error}</b> → ✅ <b>${ex.correct}</b><br><br>${ex.explanation}</div>`;
  document.getElementById('det-next').classList.add('visible');
}
function detMarkCorrectFree(){
  if(detAnswered)return;
  detAnswered=true;
  const ex=detDeck[detIdx];
  const correct=!ex.error;
  if(correct)detScore++;
  document.getElementById('det-score').textContent=detScore;
  showDetFeedback(correct);
}
function detNext(){
  if(!detAnswered) return;
  detIdx++;renderDetect();
}

/* ═══════════════════════════════════════════
   SPEAKING SIMULATOR
═══════════════════════════════════════════ */
const SPEAKING_QUESTIONS=[
  {id:'s1',category:'opinion',question:"Do you think technology has improved our lives overall?",context:"Piensa en áreas como comunicación, trabajo, salud y relaciones personales.",tips:["Usa 'On the one hand... on the other hand'","Introduce concesiones: 'While it's true that..., I would argue that...'","Menciona ejemplos concretos"],model:["On the whole, I would argue that technology has had a largely positive impact on our lives, although it is not without its drawbacks.","While it's true that social media can lead to isolation, I would argue that the benefits — particularly in terms of communication and access to information — far outweigh the negatives.","That said, there are growing concerns about digital addiction, which is something policymakers need to address urgently."]},
  {id:'s2',category:'opinion',question:"Some people believe that learning languages is less important now that technology can translate instantly. To what extent do you agree?",context:"Considera los beneficios del aprendizaje de idiomas más allá de la comunicación básica.",tips:["Matiza tu posición con 'to some extent' o 'while I accept that...'","Menciona beneficios cognitivos y culturales del aprendizaje","Usa hedging: 'It could be argued that...'"],model:["While I accept that translation apps have made basic communication easier, I would strongly disagree with the view that language learning has become redundant.","Learning a language goes far beyond mere translation — it develops cultural empathy, cognitive flexibility, and opens doors to deeper human connections.","Moreover, relying entirely on technology for communication can lead to misunderstandings, particularly in nuanced or high-stakes contexts such as business negotiations or medical consultations."]},
  {id:'s3',category:'compare',question:"Compare living in a big city versus living in the countryside. What are the main advantages and disadvantages of each?",context:"Puedes estructurar tu respuesta por categorías: trabajo, calidad de vida, servicios, comunidad.",tips:["Usa binomials: 'pros and cons', 'hustle and bustle'","Conectores de contraste: 'whereas', 'in contrast to', 'unlike'","Añade ejemplos personales o hipotéticos"],model:["City life undoubtedly offers a wider range of professional opportunities and cultural activities, though this often comes at the cost of a hectic lifestyle and higher living expenses.","The countryside, on the other hand, provides peace and quiet and a stronger sense of community, but residents may struggle with limited access to services and employment.","Ultimately, the choice depends largely on one's priorities — for career-driven individuals, the city may be more appealing, whereas those who value well-being and quality of life might prefer rural living."]},
  {id:'s4',category:'compare',question:"How does the education system in Spain compare to what you know about education in other countries?",context:"Puedes comparar métodos de enseñanza, estructura del sistema, valores educativos.",tips:["Usa 'In contrast to...' y 'Similarly...'","Evita generalizaciones absolutas: 'tends to', 'on the whole'","Muestra conocimiento del tema con vocabulario específico"],model:["In Spain, the education system tends to be more exam-focused, placing considerable emphasis on theoretical knowledge rather than critical thinking or practical skills.","In contrast, countries like Finland have adopted a more student-centred approach, with less standardised testing and greater teacher autonomy, which has yielded impressive results in terms of student well-being and performance.","That said, it would be an oversimplification to claim that one system is entirely superior — each reflects the cultural values and priorities of the society it serves."]},
  {id:'s5',category:'problem',question:"What do you think are the main challenges facing cities today, and what solutions would you suggest?",context:"Piensa en: vivienda, transporte, medioambiente, desigualdad social, gentrificación.",tips:["Estructura: problema → causa → solución","Usa pasivas para propuestas: 'should be implemented', 'needs to be addressed'","Vocabulary: urban sprawl, gentrification, sustainable living"],model:["One of the most pressing issues facing modern cities is the lack of affordable housing, which is being exacerbated by gentrification as wealthier residents displace established communities.","In order to tackle this, local councils need to invest heavily in social housing and implement rent control policies, alongside stricter regulations on short-term lettings such as Airbnb.","Furthermore, improving public transport infrastructure and encouraging the use of renewables could significantly reduce congestion and pollution, making cities more liveable for all residents."]},
  {id:'s6',category:'problem',question:"Many young people today feel disengaged from politics. What do you think are the causes of this, and how could it be addressed?",context:"Considera factores como la desconfianza en instituciones, redes sociales, falta de representación.",tips:["'This can be attributed to...' para causas","'One potential solution would be to...' para propuestas","Usa 'arguably' y 'it could be claimed that' para matizar"],model:["Political disengagement among young people can be attributed to a combination of factors, including a widespread distrust of political institutions and a perception that politicians fail to represent their interests.","This is arguably compounded by social media, which tends to promote polarised views and short-term thinking, making nuanced political debate increasingly difficult.","One potential solution would be to introduce compulsory civic education in schools, alongside lowering the voting age to 16, which could foster a stronger sense of political responsibility from an early age."]},
  {id:'s7',category:'describe',question:"Describe a time when you had to resolve a conflict or difficult situation. What did you learn from the experience?",context:"Puedes hablar de conflictos en el trabajo, con amigos, en situaciones académicas.",tips:["Usa narrative tenses: past perfect + past simple","'Looking back...' / 'In retrospect...' para reflexionar","Vocabulary: mediation, resolve, confrontation, productive outcome"],model:["I recall a situation at work where a colleague and I had conflicting views on how to approach a project, which led to a rather heated exchange in a team meeting.","Rather than allowing the situation to escalate, I suggested we meet one-on-one to address our differences constructively, which ultimately led to a more productive outcome for the whole team.","Looking back, I think the experience taught me the importance of active listening and the value of separating personal feelings from professional disagreements — skills that have proved invaluable since."]},
  {id:'s8',category:'describe',question:"Describe a cultural tradition or practice from your country that you think is particularly meaningful or interesting.",context:"Puede ser una festividad, costumbre social, práctica culinaria o tradición familiar.",tips:["'What makes this particularly special is...' (cleft sentence)","'It's not just about X, but also about Y'","Añade contexto histórico o social"],model:["One tradition I find particularly meaningful is the Spanish custom of gathering for long Sunday lunches with extended family, which I think reflects something fundamental about our culture's relationship with food and community.","What makes this especially significant is that it's not merely about eating — it's about maintaining family bonds and passing down shared stories and values from one generation to the next.","In an increasingly fast-paced world, I believe this kind of ritual serves as an important anchor, reminding us of what truly matters beyond the hustle and bustle of daily life."]},
  {id:'s9',category:'opinion',question:"To what extent do you think social media has changed the way we communicate?",context:"Piensa en relaciones personales, comunicación profesional, expresión de identidad, desinformación.",tips:["'Fundamentally' y 'profoundly' para intensificar","'That said...' para introducir contraste","Menciona tanto efectos positivos como negativos"],model:["Social media has fundamentally transformed the way we communicate, enabling instant global connectivity that would have been unimaginable just two decades ago.","That said, there is a strong argument that the quality of communication has suffered — many interactions have become superficial, performative, or driven by algorithm-induced echo chambers rather than genuine exchange.","On balance, I would argue that social media is a powerful tool that, used responsibly, can foster community and awareness, but which poses significant risks when it replaces rather than complements face-to-face interaction."]},
  {id:'s10',category:'compare',question:"Some people prefer to travel to well-known tourist destinations, while others seek out lesser-known places. Compare these two approaches to travel.",context:"Considera comodidad vs autenticidad, impacto económico, experiencia cultural.",tips:["'Whereas those who... tend to...', 'in contrast'","Usa vocab: off the beaten track, tourist trap, authentic experience","Introduce una posición personal al final"],model:["Travelling to well-known destinations offers the reassurance of established infrastructure, a wealth of attractions, and a sense of shared cultural experience, though this often comes with overcrowding and a somewhat commercialised atmosphere.","Seeking out lesser-known places, on the other hand, tends to offer a more authentic encounter with local culture and often proves more economically beneficial to smaller communities.","Personally, I find that the most rewarding trips combine both approaches — using popular destinations as a base while venturing off the beaten track to discover places that haven't yet been shaped by mass tourism."]},
];

let spDeck=[],spIdx=0,spFilter='all',spAnswering=false;

function restartSpeaking(){
  const base=spFilter==='all'?SPEAKING_QUESTIONS:SPEAKING_QUESTIONS.filter(q=>q.category===spFilter);
  spDeck=shuffle([...base]);
  spIdx=0;spAnswering=false;
  document.getElementById('sp-current').textContent=spIdx+1;
  document.getElementById('sp-total').textContent=spDeck.length;
  renderSpeaking();
}
function setSpFilter(f){
  spFilter=f;
  document.querySelectorAll('[data-spfilter]').forEach(b=>b.classList.toggle('active',b.dataset.spfilter===f));
  restartSpeaking();
}

function renderSpeaking(){
  const area=document.getElementById('sp-area');
  if(!spDeck.length){area.innerHTML=`<div class="empty-state"><div class="big">🗣️</div>Sin preguntas para este filtro.</div>`;return;}
  if(spIdx>=spDeck.length){
    area.innerHTML=`<div class="round-done"><div class="big">🎓</div><h2>¡Sesión completada!</h2><p>Has practicado las ${spDeck.length} preguntas.</p><button class="repeat-btn" onclick="restartSpeaking()">↺ Repetir</button></div>`;
    return;
  }
  const q=spDeck[spIdx];
  spAnswering=false;
  document.getElementById('sp-current').textContent=spIdx+1;
  document.getElementById('sp-total').textContent=spDeck.length;
  const catLabel={opinion:'Opinión',compare:'Comparar',problem:'Proponer soluciones',describe:'Describir'}[q.category]||q.category;
  area.innerHTML=`
    <div class="rw-card">
      <div class="quiz-meta"><span>${catLabel}</span><span>C1 Speaking</span></div>
      <div class="speaking-q">${q.question}</div>
      ${q.context?`<div class="speaking-context">💡 ${q.context}</div>`:''}
      <div style="font-size:13px;font-weight:600;color:var(--text3);margin-bottom:8px;text-transform:uppercase;letter-spacing:.05em">Puntos clave a incluir:</div>
      <div class="speaking-tips">${q.tips.map(t=>`<div class="speaking-tip">• ${t}</div>`).join('')}</div>
      <div style="font-size:13px;color:var(--text2);margin-bottom:8px">Escribe tu respuesta (mínimo 3-4 frases):</div>
      <textarea class="speaking-input" id="sp-input" placeholder="Escribe tu respuesta aquí...&#10;&#10;Intenta usar las estructuras C1 de los puntos clave."></textarea>
      <button class="speaking-submit" id="sp-submit" onclick="submitSpeaking()">Obtener feedback de IA ✨</button>
      <div id="sp-feedback"></div>
    </div>
    <div class="nav-row" style="margin-top:12px">
      <button class="nav-btn" onclick="spPrev()" ${spIdx===0?'disabled':''}>← Anterior</button>
      <button class="nav-btn" id="sp-next" onclick="spNext()" style="background:var(--accent);color:#fff;border-color:var(--accent)">Siguiente →</button>
    </div>`;
}

function submitSpeaking(){
  const input=document.getElementById('sp-input');
  const btn=document.getElementById('sp-submit');
  if(!input||input.value.trim().length<20){showToast('Escribe al menos 3-4 frases');return;}
  btn.disabled=true;btn.textContent='Ver frases modelo ✓';
  const q=spDeck[spIdx];
  const fb=document.getElementById('sp-feedback');
  // Show model phrases and tips without AI
  fb.innerHTML=`
    <div class="speaking-feedback">
      <div class="sf-section">
        <div class="sf-section-title">✅ Tu respuesta</div>
        <div class="sf-text" style="font-style:italic;padding:10px 14px;background:var(--bg2);border-radius:var(--radius);line-height:1.7">"${input.value.trim()}"</div>
      </div>
      <div class="sf-section">
        <div class="sf-section-title">💡 Puntos clave a incluir</div>
        <div class="speaking-tips">${q.tips.map(t=>`<div class="speaking-tip">• ${t}</div>`).join('')}</div>
      </div>
      <div class="sf-section">
        <div class="sf-section-title">🎯 Frases modelo C1</div>
        <div class="sf-phrases">${(q.model||[]).map(p=>`<div class="sf-phrase">"${p}"</div>`).join('')}</div>
      </div>
      <div style="font-size:12px;color:var(--text3);text-align:center;margin-top:8px">Compara tu respuesta con las frases modelo y evalúa tú mismo.</div>
    </div>`;
}

function spNext(){spIdx++;renderSpeaking();}
function spPrev(){if(spIdx>0){spIdx--;renderSpeaking();}}


